<h2 style="font-size:22px;font-weight:700;color:#373928;margin:0 0 8px;">Reset your password</h2>
<p style="font-size:15px;color:#4a5040;margin:0 0 24px;line-height:1.6;">
  We received a request to reset the password for your Save &amp; Savor account.
  Click the button below to choose a new password.
</p>

<table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
  <tr>
    <td align="center">
      <%= link_to "Reset Password", edit_password_url(@user.password_reset_token),
            style: "display:inline-block;background-color:#1a7425;color:#ffffff;font-size:15px;font-weight:600;text-decoration:none;padding:12px 28px;border-radius:8px;" %>
    </td>
  </tr>
</table>

<p style="font-size:13px;color:#81826d;margin:0 0 8px;line-height:1.5;">
  This link expires in <strong><%= distance_of_time_in_words(0, @user.password_reset_token_expires_in) %></strong>.
  If you didn't request a password reset, you can safely ignore this email &mdash; your password won't change.
</p>

<p style="font-size:12px;color:#9ca3af;margin:0;line-height:1.5;word-break:break-all;">
  Or copy this URL into your browser:<br>
  <%= edit_password_url(@user.password_reset_token) %>
</p>
