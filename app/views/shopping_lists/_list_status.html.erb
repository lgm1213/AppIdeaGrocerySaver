<%# Locals: list %>
<div id="list_status_<%= list.id %>">
  <% if list.completed? %>
    <span class="badge badge-green" style="font-size: 0.875rem; padding: 0.375rem 0.875rem;">Completed</span>
  <% else %>
    <%= button_to mark_complete_shopping_list_path(list),
          method: :patch,
          class: "btn btn-outline",
          data: { turbo_stream: true } do %>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      Mark Complete
    <% end %>
  <% end %>
</div>
