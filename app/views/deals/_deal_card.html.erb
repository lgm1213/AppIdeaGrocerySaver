<%# Locals: deal (Deal), highlight (boolean) %>
<%= link_to deal_path(deal), style: "text-decoration: none; display: block;" do %>
<div class="card card-hover" style="padding: 1.125rem 1.25rem; <%= highlight ? 'border: 2px solid #1a7425;' : '' %>">
  <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.75rem;">
    <div style="flex: 1; min-width: 0;">
      <p style="font-size: 0.75rem; font-weight: 600; color: #81826d; margin: 0 0 0.25rem;"><%= deal.store.name %></p>
      <p style="font-size: 0.9375rem; font-weight: 700; color: #373928; margin: 0; line-height: 1.3;"><%= deal.name %></p>
    </div>

    <%# Deal type badge %>
    <% badge_color = deal.deal_type == "bogo" ? "badge-green" : "badge-red" %>
    <span class="badge <%= badge_color %>" style="flex-shrink: 0; font-size: 0.6875rem; white-space: nowrap;">
      <%= deal.deal_type == "bogo" ? "BOGO" : deal.deal_type.upcase %>
    </span>
  </div>

  <%# Price / savings line %>
  <div style="margin-bottom: 0.625rem;">
    <span style="font-size: 1.25rem; font-weight: 800; color: #1a7425; font-family: 'Plus Jakarta Sans', sans-serif;">
      <%= deal.savings_label %>
    </span>
  </div>

  <div style="display: flex; align-items: center; justify-content: space-between;">
    <% if deal.valid_until %>
      <span style="font-size: 0.75rem; color: #81826d;">
        Valid through <%= deal.valid_until.strftime("%b %-d") %>
      </span>
    <% else %>
      <span style="font-size: 0.75rem; color: #81826d;"><%= deal.category %></span>
    <% end %>

    <% if deal.savings_amount&.positive? %>
      <span style="font-size: 0.75rem; font-weight: 700; color: #1a7425;">
        Save up to $<%= format("%.2f", deal.savings_amount) %>
      </span>
    <% end %>
  </div>
</div>
<% end %>
