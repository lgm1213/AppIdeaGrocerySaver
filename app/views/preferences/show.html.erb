<% content_for :page_title, "My Preferences" %>
<% content_for :header_actions do %>
  <%= link_to edit_preferences_path, class: "btn btn-primary" do %>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
    </svg>
    Edit
  <% end %>
<% end %>

<% pref = @preference %>
<div style="max-width: 40rem; display: flex; flex-direction: column; gap: 1.25rem;">

  <div class="card" style="padding: 1.75rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1.25rem;">Household & Budget</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div style="background: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Household Size</p>
        <p style="font-size: 1.5rem; font-weight: 800; color: #1a7425; margin: 0;"><%= pref.household_size %></p>
        <p style="font-size: 0.75rem; color: #81826d; margin: 0;"><%= "person".pluralize(pref.household_size) %></p>
      </div>
      <div style="background: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Weekly Budget</p>
        <p style="font-size: 1.5rem; font-weight: 800; color: #815f00; margin: 0;"><%= pref.budget_display %></p>
      </div>
      <div style="background: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Zip Code</p>
        <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0;"><%= pref.zip_code.presence || "Not set" %></p>
      </div>
      <div style="background: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Preferred Store</p>
        <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0;"><%= pref.preferred_store.presence || "Not set" %></p>
      </div>
    </div>
  </div>

  <div class="card" style="padding: 1.75rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1.25rem;">Cooking Style</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
      <div style="background: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Skill</p>
        <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0;"><%= pref.skill_label %></p>
      </div>
      <div style="background: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Complexity</p>
        <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0;"><%= pref.meal_complexity.humanize %></p>
      </div>
      <div style="background: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Meals/week</p>
        <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0;"><%= pref.meals_per_week %></p>
      </div>
    </div>

    <div style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
      <% [["Breakfast", pref.include_breakfast], ["Lunch", pref.include_lunch], ["Dinner", pref.include_dinner]].each do |label, active| %>
        <span class="<%= active ? 'chip chip-active' : 'chip chip-inactive' %>"><%= label %></span>
      <% end %>
    </div>
  </div>

  <div class="card" style="padding: 1.75rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1rem;">Dietary Restrictions</h2>
    <% if pref.dietary_restrictions.blank? %>
      <p style="color: #81826d; font-size: 0.875rem;">None set.</p>
    <% else %>
      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
        <% pref.dietary_restrictions.each do |d| %>
          <span class="badge badge-green"><%= d.humanize.titleize %></span>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
