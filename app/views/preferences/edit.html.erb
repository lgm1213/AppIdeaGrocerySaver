<% content_for :page_title, "Edit Preferences" %>
<% content_for :header_actions do %>
  <%= link_to preferences_path, class: "btn btn-ghost" do %>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    Back
  <% end %>
<% end %>

<div style="max-width: 36rem;">
  <%= form_with model: @preference, url: preferences_path, method: :patch,
        data: { controller: "onboarding" } do |f| %>

    <% if @preference.errors.any? %>
      <div class="flash flash-alert" style="margin-bottom: 1.25rem;">
        <%= @preference.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="card" style="padding: 1.75rem; margin-bottom: 1.25rem;">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1.25rem;">Household & Budget</h2>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :household_size, "Household Size", class: "input-label" %>
        <%= f.number_field :household_size, class: "input", style: "width: 8rem;", min: 1, max: 20 %>
      </div>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :weekly_budget, "Weekly Budget ($)", class: "input-label" %>
        <%= f.number_field :weekly_budget, class: "input", style: "width: 10rem;", min: 25, max: 1000, step: 5 %>
      </div>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :zip_code, "Zip Code", class: "input-label" %>
        <%= f.text_field :zip_code, class: "input", style: "width: 10rem;", maxlength: 10 %>
      </div>

      <div style="margin-bottom: 0;">
        <%= f.label :zip_code, "Zip Code", class: "input-label" %>
      </div>
    </div>

    <%# ── Grocery Stores ───────────────────────────────────────── %>
    <div class="card" style="padding: 1.75rem; margin-bottom: 1.25rem;">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 0.375rem;">Your Grocery Stores</h2>
      <p style="font-size: 0.8125rem; color: #81826d; margin: 0 0 1rem;">We pull weekly deals from these stores to build your meal plan.</p>

      <% if @available_stores.any? %>
        <div style="display: flex; flex-direction: column; gap: 0.625rem;">
          <% @available_stores.each do |store| %>
            <% checked = @selected_store_ids.include?(store.id) %>
            <label style="display: flex; align-items: center; gap: 0.875rem; padding: 0.875rem 1rem; background: <%= checked ? '#d9f5db' : '#fafaf5' %>; border: 2px solid <%= checked ? '#1a7425' : '#e9eaca' %>; border-radius: 0.875rem; cursor: pointer;">
              <input
                type="checkbox"
                name="store_ids[]"
                value="<%= store.id %>"
                <%= "checked" if checked %>
                style="width: 1.125rem; height: 1.125rem; accent-color: #1a7425; flex-shrink: 0;"
              >
              <div style="flex: 1;">
                <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0;"><%= store.name %></p>
                <p style="font-size: 0.75rem; color: #81826d; margin: 0;">
                  <% if store.deals_fetched_at %>
                    Deals last synced <%= time_ago_in_words(store.deals_fetched_at) %> ago
                  <% else %>
                    Not yet synced
                  <% end %>
                </p>
              </div>
            </label>
          <% end %>
        </div>
      <% else %>
        <p style="font-size: 0.875rem; color: #81826d; font-style: italic;">No stores available yet.</p>
      <% end %>
    </div>

    <div class="card" style="padding: 1.75rem; margin-bottom: 1.25rem;">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1.25rem;">Cooking Style</h2>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :cooking_skill, "Skill Level", class: "input-label" %>
        <%= f.select :cooking_skill,
              [["Beginner", "beginner"], ["Intermediate", "intermediate"], ["Advanced", "advanced"]],
              {}, class: "input", style: "width: 14rem;" %>
      </div>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :meal_complexity, "Meal Complexity", class: "input-label" %>
        <%= f.select :meal_complexity,
              [["Quick (under 30 min)", "quick"], ["Moderate", "moderate"], ["Elaborate", "elaborate"]],
              {}, class: "input", style: "width: 14rem;" %>
      </div>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :meals_per_week, "Meals per Week", class: "input-label" %>
        <%= f.number_field :meals_per_week, class: "input", style: "width: 8rem;", min: 1, max: 21 %>
      </div>

      <div>
        <p class="input-label" style="margin-bottom: 0.625rem;">Which meals to plan?</p>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.875rem; font-weight: 500; color: #373928;">
            <%= f.check_box :include_breakfast %> Breakfast
          </label>
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.875rem; font-weight: 500; color: #373928;">
            <%= f.check_box :include_lunch %> Lunch
          </label>
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.875rem; font-weight: 500; color: #373928;">
            <%= f.check_box :include_dinner %> Dinner
          </label>
        </div>
      </div>
    </div>

    <div class="card" style="padding: 1.75rem; margin-bottom: 1.5rem;">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1rem;">Dietary Restrictions</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
        <% UserPreference::DIETARY_OPTIONS.each do |opt| %>
          <label style="cursor: pointer;">
            <input
              type="checkbox"
              name="user_preference[dietary_restrictions][]"
              value="<%= opt %>"
              style="display: none;"
              <%= "checked" if @preference.dietary_restrictions&.include?(opt) %>
            >
            <span class="chip <%= @preference.dietary_restrictions&.include?(opt) ? 'chip-active' : 'chip-inactive' %>"
                  onclick="this.previousElementSibling.checked = !this.previousElementSibling.checked; this.classList.toggle('chip-active'); this.classList.toggle('chip-inactive');">
              <%= opt.humanize.titleize %>
            </span>
          </label>
        <% end %>
        <%# Ensure empty array is submitted when none are checked %>
        <%= hidden_field_tag "user_preference[dietary_restrictions][]", "" %>
      </div>
    </div>

    <div style="display: flex; gap: 0.75rem;">
      <%= f.submit "Save Preferences", class: "btn btn-primary" %>
      <%= link_to "Cancel", preferences_path, class: "btn btn-ghost" %>
    </div>
  <% end %>
</div>
