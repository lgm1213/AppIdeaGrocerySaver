<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Get Started — Save & Savor</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="min-height: 100vh; background-color: #fefee5; font-family: 'Be Vietnam Pro', sans-serif; display: flex; flex-direction: column;">

    <%# Top bar — logo + step indicator %>
    <header style="padding: 1.5rem 2rem; display: flex; align-items: center; justify-content: space-between; max-width: 1100px; margin: 0 auto; width: 100%;">
      <%# Logo %>
      <div style="display: flex; align-items: center; gap: 0.625rem;">
        <div style="width: 2rem; height: 2rem; background-color: #1a7425; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2a9 9 0 0 0-9 9c0 4.17 2.84 7.67 6.69 8.69L12 22l2.31-2.31C18.16 18.67 21 15.17 21 11a9 9 0 0 0-9-9z"/>
            <circle cx="12" cy="11" r="3"/>
          </svg>
        </div>
        <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.0625rem; color: #373928;">Save &amp; Savor</span>
      </div>

      <%# Step progress %>
      <div style="display: flex; align-items: center; gap: 0.5rem;" aria-label="Onboarding progress">
        <% onboarding_steps = ["Preferences", "Budget", "Review"] %>
        <% current_step_index = local_assigns[:current_step] || 0 %>
        <% onboarding_steps.each_with_index do |step, i| %>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <div style="
              width: 1.75rem; height: 1.75rem; border-radius: 9999px;
              display: flex; align-items: center; justify-content: center;
              font-size: 0.75rem; font-weight: 700;
              background-color: <%= i < current_step_index ? '#1a7425' : i == current_step_index ? '#1a7425' : '#eff0d1' %>;
              color: <%= i <= current_step_index ? 'white' : '#81826d' %>;
              transition: all 300ms ease;
            " aria-label="Step <%= i + 1 %>: <%= step %> (<%= i < current_step_index ? 'completed' : i == current_step_index ? 'current' : 'upcoming' %>)">
              <% if i < current_step_index %>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              <% else %>
                <%= i + 1 %>
              <% end %>
            </div>
            <span style="font-size: 0.8125rem; font-weight: 500; color: <%= i == current_step_index ? '#373928' : '#81826d' %>;">
              <%= step %>
            </span>
            <% if i < onboarding_steps.length - 1 %>
              <div style="width: 2rem; height: 2px; background-color: <%= i < current_step_index ? '#1a7425' : '#e9eaca' %>; border-radius: 9999px; margin: 0 0.25rem;"></div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Skip / sign out %>
      <div style="font-size: 0.875rem; color: #646652;">
        <%= button_to session_path, method: :delete, form: { "data-turbo" => "false" }, style: "background: none; border: none; cursor: pointer; color: #646652; font-size: 0.875rem; font-family: inherit; padding: 0;" do %>
          Sign out
        <% end %>
      </div>
    </header>

    <%# Progress bar %>
    <div style="max-width: 1100px; margin: 0 auto; width: 100%; padding: 0 2rem;">
      <div class="progress-track">
        <div class="progress-fill" style="width: <%= yield(:progress_percent) || '0%' %>;" aria-hidden="true"></div>
      </div>
    </div>

    <%# Main wizard content — Turbo Frame wraps the step body %>
    <main style="flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 3rem 2rem;">
      <%= turbo_frame_tag "onboarding_step", style: "width: 100%; max-width: 680px;" do %>
        <%= yield %>
      <% end %>
    </main>

  </body>
</html>
