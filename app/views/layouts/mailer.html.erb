<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body style="margin:0;padding:0;background-color:#fefee5;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;color:#373928;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#fefee5;padding:32px 16px;">
      <tr>
        <td align="center">
          <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;">

            <%# Header %>
            <tr>
              <td style="padding-bottom:24px;" align="center">
                <table cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="background-color:#1a7425;border-radius:50%;width:36px;height:36px;text-align:center;vertical-align:middle;" align="center">
                      <span style="color:#fff;font-size:18px;font-weight:bold;line-height:36px;">S</span>
                    </td>
                    <td style="padding-left:10px;font-size:20px;font-weight:800;color:#373928;vertical-align:middle;">
                      Save &amp; Savor
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <%# Content card %>
            <tr>
              <td style="background-color:#ffffff;border-radius:12px;border:1px solid #e8e9d4;padding:32px;">
                <%= yield %>
              </td>
            </tr>

            <%# Footer %>
            <tr>
              <td style="padding-top:24px;text-align:center;font-size:12px;color:#81826d;">
                Save &amp; Savor &mdash; Helping you eat well and save money.<br>
                <%= yield :footer_links %>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
