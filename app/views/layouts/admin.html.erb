<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Admin — Save & Savor" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      .admin-nav-item {
        display: flex; align-items: center; gap: 0.625rem;
        padding: 0.5rem 0.75rem; border-radius: 0.5rem;
        color: #c8caa8; text-decoration: none;
        font-size: 0.875rem; font-weight: 500;
        transition: background 0.15s, color 0.15s;
      }
      .admin-nav-item:hover { background: rgba(255,255,255,0.08); color: #fff; }
      .admin-nav-item.active { background: rgba(255,255,255,0.14); color: #fff; }
      .admin-stat-card {
        background: #fff; border-radius: 0.75rem; padding: 1.25rem 1.5rem;
        border: 1px solid #e8e9d4;
      }
      .admin-badge {
        display: inline-flex; align-items: center; gap: 0.25rem;
        padding: 0.2rem 0.6rem; border-radius: 9999px;
        font-size: 0.75rem; font-weight: 600;
      }
      .admin-badge-green  { background: #dcfce7; color: #166534; }
      .admin-badge-red    { background: #fee2e2; color: #991b1b; }
      .admin-badge-yellow { background: #fef9c3; color: #854d0e; }
      .admin-badge-gray   { background: #f1f5f9; color: #475569; }
      .admin-table { width: 100%; border-collapse: collapse; }
      .admin-table th {
        text-align: left; font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: #6b7280; padding: 0.625rem 1rem;
        border-bottom: 1px solid #e5e7eb;
      }
      .admin-table td {
        padding: 0.75rem 1rem; font-size: 0.875rem;
        border-bottom: 1px solid #f3f4f6; color: #374151;
      }
      .admin-table tr:last-child td { border-bottom: none; }
      .admin-table tr:hover td { background: #f9fafb; }
    </style>
  </head>

  <body style="min-height: 100vh; display: flex; background: #f8f9f0; font-family: 'Be Vietnam Pro', sans-serif;">

    <%# ── Admin Sidebar ──────────────────────────────────────────────── %>
    <aside style="width: 15rem; min-height: 100vh; background: #1e2318; display: flex; flex-direction: column; flex-shrink: 0; padding: 1.5rem 1rem;">

      <%# Header %>
      <div style="padding: 0 0.5rem; margin-bottom: 0.5rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.375rem;">
          <div style="width: 1.75rem; height: 1.75rem; background: #e53e3e; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1rem; color: #fff;">Admin Panel</span>
        </div>
        <p style="font-size: 0.7rem; color: #6b7a5c; margin: 0; padding-left: 2.25rem;">Save &amp; Savor</p>
      </div>

      <div style="height: 1px; background: rgba(255,255,255,0.08); margin: 1rem 0;"></div>

      <%# Navigation %>
      <nav style="flex: 1;">
        <div style="margin-bottom: 0.25rem;">
          <%= link_to admin_root_path,
                class: "admin-nav-item #{controller_name == 'dashboard' ? 'active' : ''}" do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
            Overview
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to admin_users_path,
                class: "admin-nav-item #{controller_name == 'users' ? 'active' : ''}" do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            Users
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to admin_jobs_path,
                class: "admin-nav-item #{controller_name == 'jobs' ? 'active' : ''}" do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
            </svg>
            Jobs
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to admin_job_executions_path,
                class: "admin-nav-item #{controller_name == 'job_executions' ? 'active' : ''}" do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
            </svg>
            Job History
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to admin_system_health_path,
                class: "admin-nav-item #{controller_name == 'system_health' ? 'active' : ''}" do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
            System Health
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to admin_email_settings_path,
                class: "admin-nav-item #{controller_name == 'email_settings' ? 'active' : ''}" do %>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Email / SMTP
          <% end %>
        </div>
      </nav>

      <%# Footer %>
      <div style="height: 1px; background: rgba(255,255,255,0.08); margin-bottom: 1rem;"></div>
      <div style="padding: 0 0.5rem;">
        <%= link_to dashboard_path, style: "display: flex; align-items: center; gap: 0.5rem; color: #6b7a5c; text-decoration: none; font-size: 0.8125rem; font-weight: 500;" do %>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
          Exit to App
        <% end %>
        <p style="font-size: 0.7rem; color: #4a5040; margin: 0.5rem 0 0; padding-left: 1.375rem;">
          <%= Current.user.email_address %>
        </p>
      </div>
    </aside>

    <%# ── Main ─────────────────────────────────────────────────────── %>
    <div style="flex: 1; display: flex; flex-direction: column; min-width: 0;">

      <%# Top bar %>
      <header style="background: #fff; border-bottom: 1px solid #e5e7eb; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 30;">
        <div>
          <% if content_for?(:page_title) %>
            <h1 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.25rem; font-weight: 700; color: #111827; margin: 0;">
              <%= yield :page_title %>
            </h1>
          <% end %>
          <% if content_for?(:page_subtitle) %>
            <p style="font-size: 0.8125rem; color: #6b7280; margin: 0.125rem 0 0;"><%= yield :page_subtitle %></p>
          <% end %>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <%= yield :header_actions %>
        </div>
      </header>

      <%# Flash %>
      <% if notice.present? %>
        <div style="padding: 1rem 2rem 0;">
          <div style="background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; padding: 0.75rem 1rem; border-radius: 0.5rem; font-size: 0.875rem;">
            <%= notice %>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div style="padding: 1rem 2rem 0;">
          <div style="background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: 0.75rem 1rem; border-radius: 0.5rem; font-size: 0.875rem;">
            <%= alert %>
          </div>
        </div>
      <% end %>

      <main style="flex: 1; padding: 2rem;">
        <%= yield %>
      </main>
    </div>

  </body>
</html>
