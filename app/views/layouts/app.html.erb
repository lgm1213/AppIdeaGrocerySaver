<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Save & Savor" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Save & Savor">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex" style="background-color: #fefee5; font-family: 'Be Vietnam Pro', sans-serif;">

    <%# ── Sidebar ──────────────────────────────────────────────────────── %>
    <aside
      id="app-sidebar"
      class="flex-shrink-0 flex flex-col"
      style="width: 16rem; min-height: 100vh; background-color: #fbfbe0; padding: 1.5rem 1rem;"
      data-controller="sidebar"
    >
      <%# Logo %>
      <div style="padding: 0 0.5rem; margin-bottom: 2.5rem;">
        <%= link_to dashboard_path, style: "text-decoration: none; display: flex; align-items: center; gap: 0.625rem;" do %>
          <div style="width: 2.25rem; height: 2.25rem; background-color: #1a7425; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2a9 9 0 0 0-9 9c0 4.17 2.84 7.67 6.69 8.69L12 22l2.31-2.31C18.16 18.67 21 15.17 21 11a9 9 0 0 0-9-9z"/>
              <circle cx="12" cy="11" r="3"/>
            </svg>
          </div>
          <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.125rem; color: #373928;">Save &amp; Savor</span>
        <% end %>
      </div>

      <%# Primary Navigation %>
      <nav class="flex-1" aria-label="Main navigation">
        <div style="margin-bottom: 0.25rem;">
          <%= link_to dashboard_path,
                class: "nav-item #{current_page?(dashboard_path) ? 'active' : ''}",
                aria: { current: current_page?(dashboard_path) ? "page" : nil } do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
            Dashboard
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to meal_plans_path,
                class: "nav-item #{controller_name == 'meal_plans' ? 'active' : ''}",
                aria: { current: controller_name == 'meal_plans' ? "page" : nil } do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Meal Planner
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%# Meal Generator - singular resource %>
          <%= link_to new_meal_generator_path,
                class: "nav-item #{controller_name == 'meal_generators' ? 'active' : ''}",
                aria: { current: controller_name == 'meal_generators' ? "page" : nil } do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            Meal Generator
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to shopping_lists_path,
                class: "nav-item #{controller_name == 'shopping_lists' ? 'active' : ''}",
                aria: { current: controller_name == 'shopping_lists' ? "page" : nil } do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            Shopping Lists
          <% end %>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to deals_path,
                class: "nav-item #{controller_name == 'deals' ? 'active' : ''}",
                aria: { current: controller_name == 'deals' ? "page" : nil } do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 12 20 22 4 22 4 12"/>
              <rect x="2" y="7" width="20" height="5"/>
              <line x1="12" y1="22" x2="12" y2="7"/>
              <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
              <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
            </svg>
            Weekly Deals
          <% end %>
        </div>

        <%# Section divider via spacing — no line %>
        <div style="margin-top: 1.5rem; margin-bottom: 0.5rem; padding: 0 0.5rem;">
          <span style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d;">Account</span>
        </div>

        <div style="margin-bottom: 0.25rem;">
          <%= link_to edit_settings_path,
                class: "nav-item #{controller_name == 'settings' ? 'active' : ''}",
                aria: { current: controller_name == 'settings' ? "page" : nil } do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
            Settings
          <% end %>
        </div>
      </nav>

      <%# User info at bottom %>
      <div style="padding: 0.75rem; background-color: #eff0d1; border-radius: 0.75rem; margin-top: 1rem;">
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <div class="avatar avatar-md" aria-hidden="true">
            <%= Current.user.initials %>
          </div>
          <div style="flex: 1; min-width: 0;">
            <p style="font-size: 0.8125rem; font-weight: 600; color: #373928; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              <%= Current.user.email_address %>
            </p>
          </div>
          <%= button_to session_path,
                method: :delete,
                class: "btn btn-sm btn-ghost",
                style: "flex-shrink: 0; padding: 0.375rem;",
                form: { "data-turbo" => "false" },
                title: "Sign out",
                aria: { label: "Sign out" } do %>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          <% end %>
        </div>
      </div>
    </aside>

    <%# ── Main content area ───────────────────────────────────────────── %>
    <div class="flex-1 flex flex-col min-w-0">
      <%# Top bar %>
      <header style="background-color: #fbfbe0; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 30; backdrop-filter: blur(12px);">
        <div>
          <% if content_for?(:page_title) %>
            <h1 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.375rem; font-weight: 700; color: #373928; margin: 0; letter-spacing: -0.02em;">
              <%= yield :page_title %>
            </h1>
          <% end %>
          <% if content_for?(:page_subtitle) %>
            <p style="font-size: 0.875rem; color: #646652; margin: 0;">
              <%= yield :page_subtitle %>
            </p>
          <% end %>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <%= yield :header_actions %>
        </div>
      </header>

      <%# New deals notification banner %>
      <% if new_deals_available? %>
        <div style="padding: 1rem 0 0;">
          <%= render "shared/deals_notification" %>
        </div>
      <% end %>

      <%# Flash messages %>
      <% if notice.present? %>
        <div style="padding: 1rem 2rem 0;" data-controller="flash">
          <div class="flash flash-notice"><%= notice %></div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div style="padding: 1rem 2rem 0;" data-controller="flash">
          <div class="flash flash-alert"><%= alert %></div>
        </div>
      <% end %>

      <%# Page content %>
      <main style="flex: 1; padding: 2rem;" id="main-content">
        <%= yield %>
      </main>
    </div>

  </body>
</html>
