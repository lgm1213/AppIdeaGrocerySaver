<% content_for :title, "Create Account — Save & Savor" %>

<div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
  <div style="width: 100%; max-width: 26rem;">

    <%# Logo %>
    <div style="text-align: center; margin-bottom: 2.5rem;">
      <%= link_to root_path, style: "display: inline-flex; align-items: center; gap: 0.625rem; text-decoration: none; margin-bottom: 1.5rem;" do %>
        <div style="width: 2.5rem; height: 2.5rem; background-color: #1a7425; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><path d="M8.5 14.5s1.5 2 3.5 2 3.5-2 3.5-2"/><path d="M9 9h.01M15 9h.01"/>
          </svg>
        </div>
        <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.25rem; color: #373928;">Save &amp; Savor</span>
      <% end %>
      <h1 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #373928; margin: 0 0 0.375rem;">Create your account</h1>
      <p style="font-size: 0.9375rem; color: #646652; margin: 0;">Free forever. No credit card needed.</p>
    </div>

    <div class="card" style="padding: 2rem;">

      <%# Google OAuth %>
      <%= button_to "/auth/google_oauth2",
            method: :post,
            style: "width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.625rem; padding: 0.75rem 1.5rem; background-color: white; border: 1.5px solid #e9eaca; border-radius: 9999px; font-family: 'Be Vietnam Pro', sans-serif; font-size: 0.9375rem; font-weight: 600; color: #373928; cursor: pointer; margin-bottom: 1.5rem; transition: all 140ms;" do %>
        <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Sign up with Google
      <% end %>

      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <div style="flex: 1; height: 1px; background-color: #e9eaca;"></div>
        <span style="font-size: 0.8125rem; color: #81826d; font-weight: 500; white-space: nowrap;">or sign up with email</span>
        <div style="flex: 1; height: 1px; background-color: #e9eaca;"></div>
      </div>

      <%= form_with model: @user, url: registration_path do |f| %>

        <%# Validation errors %>
        <% if @user.errors.any? %>
          <div class="flash flash-alert" style="margin-bottom: 1.25rem; flex-direction: column; align-items: flex-start; gap: 0.375rem;">
            <p style="font-weight: 700; margin: 0; font-size: 0.875rem;"><%= pluralize(@user.errors.count, "error") %> prevented sign up:</p>
            <ul style="margin: 0; padding-left: 1.25rem; font-size: 0.875rem;">
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div style="margin-bottom: 1rem;">
          <label class="input-label" for="user_email_address">Email address</label>
          <%= f.email_field :email_address,
                id: "user_email_address",
                class: "input",
                required: true,
                autofocus: true,
                autocomplete: "email",
                placeholder: "you@example.com" %>
        </div>

        <div style="margin-bottom: 1rem;">
          <label class="input-label" for="user_password">Password</label>
          <%= f.password_field :password,
                id: "user_password",
                class: "input",
                required: true,
                autocomplete: "new-password",
                placeholder: "At least 12 characters",
                minlength: 12 %>
          <p style="font-size: 0.8125rem; color: #81826d; margin: 0.375rem 0 0;">Must be at least 12 characters</p>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <label class="input-label" for="user_password_confirmation">Confirm password</label>
          <%= f.password_field :password_confirmation,
                id: "user_password_confirmation",
                class: "input",
                required: true,
                autocomplete: "new-password",
                placeholder: "Repeat your password" %>
        </div>

        <%= f.submit "Create Account", class: "btn btn-primary", style: "width: 100%; justify-content: center;" %>

        <p style="font-size: 0.8125rem; color: #81826d; text-align: center; margin: 1rem 0 0; line-height: 1.5;">
          By signing up you agree to our
          <a href="#" style="color: #1a7425;">Terms of Service</a> and
          <a href="#" style="color: #1a7425;">Privacy Policy</a>.
        </p>
      <% end %>
    </div>

    <p style="text-align: center; margin-top: 1.5rem; font-size: 0.9375rem; color: #646652;">
      Already have an account?
      <%= link_to "Sign in", new_session_path, style: "color: #1a7425; font-weight: 600;" %>
    </p>

  </div>
</div>
