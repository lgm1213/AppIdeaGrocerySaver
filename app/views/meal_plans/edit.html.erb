<% content_for :page_title, "Edit Plan" %>
<% content_for :header_actions do %>
  <%= link_to calendar_meal_plan_path(@meal_plan), class: "btn btn-ghost" do %>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    Back
  <% end %>
<% end %>

<div style="max-width: 32rem; margin: 0 auto;">
  <div class="card" style="padding: 2rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.25rem; font-weight: 700; color: #373928; margin: 0 0 1.5rem;">Edit Meal Plan</h2>

    <%= form_with model: @meal_plan, url: meal_plan_path(@meal_plan), method: :patch do |f| %>
      <% if @meal_plan.errors.any? %>
        <div class="flash flash-alert" style="margin-bottom: 1.25rem;">
          <%= @meal_plan.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :name, "Plan Name", class: "input-label" %>
        <%= f.text_field :name, class: "input", style: "width: 100%;" %>
      </div>

      <div style="margin-bottom: 1.5rem;">
        <%= f.label :week_start_date, "Week Starting", class: "input-label" %>
        <%= f.date_field :week_start_date, class: "input", style: "width: 100%;" %>
      </div>

      <div style="display: flex; gap: 0.75rem;">
        <%= f.submit "Save Changes", class: "btn btn-primary" %>
        <%= link_to "Cancel", calendar_meal_plan_path(@meal_plan), class: "btn btn-ghost" %>
      </div>
    <% end %>

    <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 2px solid #eff0d1;">
      <h3 style="font-size: 0.875rem; font-weight: 700; color: #c22225; margin: 0 0 0.75rem;">Danger Zone</h3>
      <%= button_to meal_plan_path(@meal_plan),
            method: :delete,
            class: "btn btn-sm",
            style: "background-color: #fde8e8; color: #c22225; border-color: #fde8e8;",
            data: { turbo_confirm: "Delete '#{@meal_plan.name}'? This cannot be undone." } do %>
        Delete this plan
      <% end %>
    </div>
  </div>
</div>
