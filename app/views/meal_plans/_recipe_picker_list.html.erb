<%# Locals: recipes, meal_plan, day, slot, entry_id %>
<%= turbo_frame_tag "recipe_picker_list" do %>
<div style="max-height: 22rem; overflow-y: auto; display: flex; flex-direction: column; gap: 0.375rem;">
  <% if recipes.empty? %>
    <div class="empty-state" style="padding: 2rem;">
      <p style="color: #81826d; font-size: 0.875rem; margin: 0;">No recipes found. Try a different search.</p>
    </div>
  <% else %>
    <% recipes.each do |recipe| %>
      <%# Each row is a form that creates/updates an entry %>
      <%= form_with(
            url: entry_id.present? ? meal_plan_meal_plan_entry_path(meal_plan, entry_id) : meal_plan_meal_plan_entries_path(meal_plan),
            method: entry_id.present? ? :patch : :post,
            scope: :meal_plan_entry,
            data: { turbo_stream: true, turbo_frame: "_top" }
          ) do |f| %>
        <%= f.hidden_field :recipe_id,   value: recipe.id %>
        <%= f.hidden_field :day_of_week, value: day %>
        <%= f.hidden_field :meal_slot,   value: slot %>
        <%= f.hidden_field :servings,    value: 2 %>

        <button
          type="submit"
          style="width: 100%; text-align: left; background: none; border: none; padding: 0; cursor: pointer;"
          data-action="click->modal#close"
        >
          <div class="card card-hover" style="padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.875rem;">
            <%# Icon placeholder %>
            <div style="width: 2.75rem; height: 2.75rem; background-color: #eff0d1; border-radius: 0.625rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#81826d" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
                <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
              </svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <p style="font-size: 0.875rem; font-weight: 600; color: #373928; margin: 0 0 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= recipe.name %></p>
              <div style="display: flex; align-items: center; gap: 0.75rem;">
                <span style="font-size: 0.75rem; color: #81826d;"><%= recipe.total_time_label %></span>
                <span style="font-size: 0.75rem; color: #81826d;"><%= recipe.cost_display %></span>
                <% recipe.dietary_badges.first(2).each do |badge| %>
                  <span class="badge badge-green" style="font-size: 0.5625rem;"><%= badge %></span>
                <% end %>
              </div>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0;">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </div>
        </button>
      <% end %>
    <% end %>
  <% end %>
</div>
<% end %>
