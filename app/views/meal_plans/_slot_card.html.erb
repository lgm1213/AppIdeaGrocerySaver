<%# locals: (meal_plan:, entry:, deal_savings: {}) %>
<% savings = deal_savings[entry.recipe_id].to_f %>
<div
  class="<%= entry.cooked? ? 'card' : 'card card-hover' %>"
  style="padding: 0.625rem; position: relative; min-height: 5.5rem; <%= entry.cooked? ? 'opacity: 0.7;' : '' %>"
  data-controller="slot-card"
  data-action="mouseenter->slot-card#mouseenter mouseleave->slot-card#mouseleave focusin->slot-card#focusin focusout->slot-card#focusout"
>
  <%# Cooked overlay checkmark %>
  <% if entry.cooked? %>
    <div style="position: absolute; top: 0.5rem; right: 0.5rem; width: 1.25rem; height: 1.25rem; background-color: #1a7425; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </div>
  <% end %>

  <%# Deal savings banner %>
  <% if savings > 0 && !entry.cooked? %>
    <div style="display: flex; align-items: center; gap: 0.25rem; margin-bottom: 0.3rem;">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>
      </svg>
      <span style="font-size: 0.5625rem; font-weight: 700; color: #1a7425; letter-spacing: 0.02em;">
        SAVES ~$<%= format("%.2f", savings) %>
      </span>
    </div>
  <% end %>

  <%# Recipe name %>
  <p style="font-size: 0.75rem; font-weight: 600; color: #373928; margin: 0 0 0.375rem; line-height: 1.3; padding-right: <%= entry.cooked? ? '1.5rem' : '0' %>;">
    <%= entry.recipe.name %>
  </p>

  <%# Dietary badges %>
  <% badges = entry.recipe.dietary_badges.first(2) %>
  <% if badges.any? %>
    <div style="display: flex; gap: 0.25rem; flex-wrap: wrap; margin-bottom: 0.375rem;">
      <% badges.each do |badge| %>
        <span class="badge badge-green" style="font-size: 0.5625rem; padding: 0.125rem 0.375rem;"><%= badge %></span>
      <% end %>
    </div>
  <% end %>

  <%# Cost + time %>
  <div style="display: flex; align-items: center; justify-content: space-between; margin-top: auto;">
    <span style="font-size: 0.6875rem; color: #81826d;"><%= entry.cost_display %></span>
    <span style="font-size: 0.6875rem; color: #81826d;"><%= entry.recipe.total_time_label %></span>
  </div>

  <%# Hover actions — 2×2 grid to keep cards compact %>
  <div
    class="slot-actions"
    style="position: absolute; inset: 0; background: rgba(255,255,255,0.92); border-radius: inherit; display: none; flex-direction: column; align-items: stretch; justify-content: center; gap: 0.3rem; padding: 0.4rem;"
    data-slot-card-target="actions"
  >
    <%# Top row: View + Cook %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.3rem;">
      <button
        type="button"
        class="btn btn-sm btn-surface"
        style="font-size: 0.625rem; padding: 0.3rem 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
        data-action="click->recipe-modal#open"
        data-recipe-modal-recipe-id-param="<%= entry.recipe_id %>"
      >
        View Recipe
      </button>

      <%= button_to toggle_cooked_meal_plan_meal_plan_entry_path(meal_plan, entry),
            method: :patch,
            class: "btn btn-sm #{entry.cooked? ? 'btn-surface' : 'btn-primary'}",
            style: "font-size: 0.625rem; padding: 0.3rem 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;",
            data: { turbo_stream: true } do %>
        <%= entry.cooked? ? "Unmark" : "Mark Cooked" %>
      <% end %>
    </div>

    <%# Bottom row: Swap + Remove %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.3rem;">
      <button
        type="button"
        class="btn btn-sm btn-outline"
        style="font-size: 0.625rem; padding: 0.3rem 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
        data-action="click->calendar#openPicker"
        data-day="<%= entry.day_of_week %>"
        data-slot="<%= entry.meal_slot %>"
        data-entry-id="<%= entry.id %>"
      >
        Swap
      </button>

      <%= button_to meal_plan_meal_plan_entry_path(meal_plan, entry),
            method: :delete,
            class: "btn btn-sm btn-ghost",
            style: "font-size: 0.625rem; padding: 0.3rem 0.25rem; color: #c22225; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;",
            data: { turbo_stream: true, turbo_confirm: "Remove this recipe?" } do %>
        Remove
      <% end %>
    </div>
  </div>
</div>
