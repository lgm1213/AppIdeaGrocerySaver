<%# Locals: meal_plan, day, slot %>
<button
  type="button"
  class="btn btn-ghost"
  style="width: 100%; min-height: 5.5rem; border: 2px dashed #d0d1b3; border-radius: 0.875rem; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.375rem; color: #81826d; transition: border-color 0.15s, background 0.15s;"
  data-action="click->calendar#openPicker"
  data-day="<%= day %>"
  data-slot="<%= slot %>"
  data-entry-id=""
  aria-label="Add <%= slot %> recipe for <%= MealPlan::DAYS[day] %>"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
  </svg>
  <span style="font-size: 0.6875rem; font-weight: 600;">Add recipe</span>
</button>
