<% content_for :page_title, "New Meal Plan" %>
<% content_for :header_actions do %>
  <%= link_to meal_plans_path, class: "btn btn-ghost" do %>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    Back
  <% end %>
<% end %>

<div style="max-width: 32rem; margin: 0 auto;">
  <div class="card" style="padding: 2rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.25rem; font-weight: 700; color: #373928; margin: 0 0 1.5rem;">Create a Meal Plan</h2>

    <%= form_with model: @meal_plan, url: meal_plans_path do |f| %>
      <% if @meal_plan.errors.any? %>
        <div class="flash flash-alert" style="margin-bottom: 1.25rem;">
          <%= @meal_plan.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :name, "Plan Name", class: "input-label" %>
        <%= f.text_field :name,
              class: "input",
              style: "width: 100%;",
              placeholder: "e.g. Week of Apr 7, 2026" %>
      </div>

      <div style="margin-bottom: 1.5rem;">
        <%= f.label :week_start_date, "Week Starting", class: "input-label" %>
        <%= f.date_field :week_start_date,
              class: "input",
              style: "width: 100%;",
              value: @meal_plan.week_start_date %>
        <p style="font-size: 0.75rem; color: #81826d; margin: 0.375rem 0 0;">Plans start on Monday.</p>
      </div>

      <div style="display: flex; gap: 0.75rem;">
        <%= f.submit "Create Plan", class: "btn btn-primary" %>
        <%= link_to "Cancel", meal_plans_path, class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>
</div>
