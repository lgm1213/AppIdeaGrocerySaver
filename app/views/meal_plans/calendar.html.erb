<% content_for :page_title, @meal_plan.name %>
<% content_for :page_subtitle, @meal_plan.week_label %>
<% content_for :header_actions do %>
  <%= button_to generate_meal_plan_path(@meal_plan),
        method: :post,
        class: "btn btn-outline",
        data: { turbo_stream: true } do %>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="1 4 1 10 7 10"/><polyline points="23 20 23 14 17 14"/>
      <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/>
    </svg>
    Regenerate
  <% end %>
  <%= button_to generate_from_plan_shopping_lists_path,
        method: :post,
        params: { meal_plan_id: @meal_plan.id },
        class: "btn btn-surface" do %>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
      <line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
    </svg>
    Shopping List
  <% end %>
  <%= link_to meal_plans_path, class: "btn btn-ghost" do %>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    All Plans
  <% end %>
<% end %>

<%# Wrap everything the calendar controller needs in a single element %>
<div data-controller="calendar" data-meal-plan-id="<%= @meal_plan.id %>">

<%# Stats strip %>
<div style="display: flex; gap: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap;">
  <div class="card-tonal" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1.25rem; border-radius: 0.875rem; flex: 1; min-width: 10rem;">
    <div style="width: 2.25rem; height: 2.25rem; background-color: #d9f5db; border-radius: 0.625rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5z"/>
        <path d="M20.5 10H19V8.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
        <path d="M9.5 14c.83 0 1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5S8 21.33 8 20.5v-5c0-.83.67-1.5 1.5-1.5z"/>
        <path d="M3.5 14H5v1.5c0 .83-.67 1.5-1.5 1.5S2 16.33 2 15.5 2.67 14 3.5 14z"/>
        <path d="M14 14.5c0-.83.67-1.5 1.5-1.5h5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-5c-.83 0-1.5-.67-1.5-1.5z"/>
        <path d="M15.5 19H14v1.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5-.67-1.5-1.5-1.5z"/>
        <path d="M10 9.5C10 8.67 9.33 8 8.5 8h-5C2.67 8 2 8.67 2 9.5S2.67 11 3.5 11h5c.83 0 1.5-.67 1.5-1.5z"/>
        <path d="M8.5 5H10V3.5C10 2.67 9.33 2 8.5 2S7 2.67 7 3.5 7.67 5 8.5 5z"/>
      </svg>
    </div>
    <div>
      <p style="font-size: 1.25rem; font-weight: 800; color: #1a7425; margin: 0; font-family: 'Plus Jakarta Sans', sans-serif;"><%= @meal_plan.total_recipes %></p>
      <p style="font-size: 0.75rem; color: #81826d; margin: 0;">recipes planned</p>
    </div>
  </div>

  <div class="card-tonal" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1.25rem; border-radius: 0.875rem; flex: 1; min-width: 10rem;">
    <div style="width: 2.25rem; height: 2.25rem; background-color: #fff3cd; border-radius: 0.625rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#815f00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
      </svg>
    </div>
    <div>
      <p style="font-size: 1.25rem; font-weight: 800; color: #815f00; margin: 0; font-family: 'Plus Jakarta Sans', sans-serif;"><%= @meal_plan.estimated_cost_display %></p>
      <p style="font-size: 0.75rem; color: #81826d; margin: 0;">est. weekly cost</p>
    </div>
  </div>

  <div class="card-tonal" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.875rem 1.25rem; border-radius: 0.875rem; flex: 1; min-width: 10rem;">
    <div style="width: 2.25rem; height: 2.25rem; background-color: #d9f5db; border-radius: 0.625rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </div>
    <div>
      <p style="font-size: 1.25rem; font-weight: 800; color: #373928; margin: 0; font-family: 'Plus Jakarta Sans', sans-serif;"><%= @meal_plan.completion_percentage %>%</p>
      <p style="font-size: 0.75rem; color: #81826d; margin: 0;">meals cooked</p>
    </div>
  </div>
</div>

<%# Calendar grid — wrapped in Turbo Frame so Regenerate can swap it %>
<%= turbo_frame_tag "meal_plan_calendar" do %>
  <%= render "meal_plans/calendar_grid",
        meal_plan: @meal_plan,
        grid: @grid,
        days: @days,
        meal_slots: @meal_slots,
        deal_savings: @deal_savings %>
<% end %>

<%# Recipe picker modal — hidden, shown by Stimulus %>
<div
  id="recipe-picker-modal"
  style="display: none; position: fixed; inset: 0; z-index: 50; overflow-y: auto;"
  data-controller="modal"
  aria-modal="true"
  role="dialog"
  aria-labelledby="picker-modal-title"
>
  <%# Overlay %>
  <div
    style="position: fixed; inset: 0; background: rgba(55, 57, 40, 0.5); backdrop-filter: blur(4px);"
    data-action="click->modal#close"
  ></div>

  <%# Panel %>
  <div style="position: relative; z-index: 10; margin: 3rem auto; max-width: 42rem; padding: 0 1rem;">
    <div class="card" style="padding: 1.5rem;">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
        <h2 id="picker-modal-title" style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.125rem; font-weight: 700; color: #373928; margin: 0;">
          Pick a Recipe
        </h2>
        <button
          type="button"
          class="btn btn-ghost btn-sm"
          data-action="click->modal#close"
          aria-label="Close"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <%# Search input %>
      <div style="position: relative; margin-bottom: 1rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#81826d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
             style="position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%); pointer-events: none;">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="text"
          placeholder="Search recipes…"
          class="input"
          style="padding-left: 2.625rem; width: 100%;"
          data-action="input->calendar#filterRecipes"
          data-calendar-target="recipeSearch"
        >
      </div>

      <%# Slot info (populated by Stimulus) %>
      <p style="font-size: 0.8125rem; color: #81826d; margin: 0 0 1rem;" data-calendar-target="slotLabel"></p>

      <%# Recipe list — turbo-frame; src set by calendar_controller when a slot opens %>
      <%= turbo_frame_tag "recipe_picker_list",
            loading: :lazy,
            style: "display: block; min-height: 6rem;" do %>
        <p style="color: #81826d; font-size: 0.875rem; padding: 2rem; text-align: center;">
          Open a slot to browse recipes.
        </p>
      <% end %>
    </div>
  </div>
</div>

</div><%# /data-controller="calendar" %>
