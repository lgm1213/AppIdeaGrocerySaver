<% content_for :page_title, "Meal Plans" %>
<% content_for :page_subtitle, "Plan your meals, save on groceries" %>
<% content_for :header_actions do %>
  <%= link_to new_meal_plan_path, class: "btn btn-primary" do %>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    New Plan
  <% end %>
<% end %>

<% if @meal_plans.empty? %>
  <div class="empty-state">
    <div style="width: 4rem; height: 4rem; background-color: #d9f5db; border-radius: 9999px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
    </div>
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.25rem; font-weight: 700; color: #373928; margin: 0 0 0.5rem;">No meal plans yet</h2>
    <p style="color: #646652; margin: 0 0 1.5rem;">Create your first plan and let us fill it with recipes you'll love.</p>
    <%= link_to "Create my first plan", new_meal_plan_path, class: "btn btn-primary" %>
  </div>

<% else %>
  <%# Current week callout %>
  <% if @current_plan %>
    <div style="margin-bottom: 2rem;">
      <div class="card" style="background: linear-gradient(135deg, #1a7425 0%, #25a334 100%); color: white; padding: 1.5rem 2rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
          <div>
            <p style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.75; margin: 0 0 0.25rem;">Current Week</p>
            <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.375rem; font-weight: 700; margin: 0 0 0.25rem;"><%= @current_plan.name %></h2>
            <p style="font-size: 0.875rem; opacity: 0.85; margin: 0;"><%= @current_plan.week_label %></p>
          </div>
          <div style="display: flex; align-items: center; gap: 1rem;">
            <div style="text-align: center;">
              <p style="font-size: 1.5rem; font-weight: 800; margin: 0;"><%= @current_plan.total_recipes %></p>
              <p style="font-size: 0.75rem; opacity: 0.75; margin: 0;">recipes</p>
            </div>
            <div style="text-align: center;">
              <p style="font-size: 1.5rem; font-weight: 800; margin: 0;"><%= @current_plan.completion_percentage %>%</p>
              <p style="font-size: 0.75rem; opacity: 0.75; margin: 0;">cooked</p>
            </div>
            <%= link_to calendar_meal_plan_path(@current_plan),
                  style: "display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.2); color: white; border-radius: 9999px; padding: 0.625rem 1.25rem; font-weight: 600; font-size: 0.875rem; text-decoration: none; transition: background 0.15s;" do %>
              View Calendar
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# All plans grid %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr)); gap: 1.25rem;">
    <% @meal_plans.each do |plan| %>
      <div class="card card-hover" style="padding: 1.25rem 1.5rem;">
        <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1rem;">
          <div style="flex: 1; min-width: 0;">
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;">
              <% if plan.current_week? %>
                <span class="badge badge-green">This Week</span>
              <% end %>
              <% if plan.archived? %>
                <span class="badge badge-surface">Archived</span>
              <% end %>
            </div>
            <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 0.25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              <%= plan.name %>
            </h3>
            <p style="font-size: 0.8125rem; color: #81826d; margin: 0;"><%= plan.week_label %></p>
          </div>
        </div>

        <%# Stats row %>
        <div style="display: flex; gap: 1.25rem; margin-bottom: 1.25rem;">
          <div>
            <p style="font-size: 1.125rem; font-weight: 700; color: #1a7425; margin: 0;"><%= plan.total_recipes %></p>
            <p style="font-size: 0.75rem; color: #81826d; margin: 0;">recipes</p>
          </div>
          <div>
            <p style="font-size: 1.125rem; font-weight: 700; color: #373928; margin: 0;"><%= plan.estimated_cost_display %></p>
            <p style="font-size: 0.75rem; color: #81826d; margin: 0;">est. cost</p>
          </div>
          <div>
            <p style="font-size: 1.125rem; font-weight: 700; color: #373928; margin: 0;"><%= plan.completion_percentage %>%</p>
            <p style="font-size: 0.75rem; color: #81826d; margin: 0;">cooked</p>
          </div>
        </div>

        <%# Progress bar %>
        <div class="progress-track" style="margin-bottom: 1.25rem;">
          <div class="progress-fill" style="width: <%= plan.completion_percentage %>%;"></div>
        </div>

        <%# Actions %>
        <div style="display: flex; gap: 0.5rem;">
          <%= link_to calendar_meal_plan_path(plan), class: "btn btn-sm btn-primary" do %>
            View Calendar
          <% end %>
          <%= link_to edit_meal_plan_path(plan), class: "btn btn-sm btn-outline" do %>
            Edit
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
