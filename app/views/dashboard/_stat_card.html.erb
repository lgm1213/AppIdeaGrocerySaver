<%# Locals: label, value, sub, color, bg %>
<div class="card-tonal" style="padding: 1.25rem; border-radius: 1rem;">
  <div style="width: 2rem; height: 2rem; background-color: <%= bg %>; border-radius: 0.5rem; margin-bottom: 0.875rem;"></div>
  <p style="font-size: 1.75rem; font-weight: 800; color: <%= color %>; margin: 0; font-family: 'Plus Jakarta Sans', sans-serif; line-height: 1;"><%= value %></p>
  <p style="font-size: 0.8125rem; font-weight: 600; color: #373928; margin: 0.25rem 0 0.125rem;"><%= label %></p>
  <p style="font-size: 0.75rem; color: #81826d; margin: 0;"><%= sub %></p>
</div>
