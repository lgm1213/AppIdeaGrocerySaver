<div class="card" style="padding: 1.5rem;">
  <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1rem;">
    Quick Actions
  </h2>

  <div style="display: flex; flex-direction: column; gap: 0.5rem;">

    <%= link_to new_meal_generator_path,
          style: "display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: #f7f8e8; border-radius: 0.75rem; text-decoration: none; transition: background 0.15s;" do %>
      <div style="width: 2rem; height: 2rem; background: #d9f5db; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </div>
      <div>
        <p style="font-size: 0.875rem; font-weight: 600; color: #373928; margin: 0;">Generate Meal Plan</p>
        <p style="font-size: 0.75rem; color: #81826d; margin: 0;">AI picks meals for the week</p>
      </div>
    <% end %>

    <%= link_to new_meal_plan_path,
          style: "display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: #f7f8e8; border-radius: 0.75rem; text-decoration: none; transition: background 0.15s;" do %>
      <div style="width: 2rem; height: 2rem; background: #fff3cd; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#815f00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </div>
      <div>
        <p style="font-size: 0.875rem; font-weight: 600; color: #373928; margin: 0;">New Meal Plan</p>
        <p style="font-size: 0.75rem; color: #81826d; margin: 0;">Build your own week manually</p>
      </div>
    <% end %>

    <%= link_to shopping_lists_path,
          style: "display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: #f7f8e8; border-radius: 0.75rem; text-decoration: none; transition: background 0.15s;" do %>
      <div style="width: 2rem; height: 2rem; background: #eff0d1; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#373928" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
      </div>
      <div>
        <p style="font-size: 0.875rem; font-weight: 600; color: #373928; margin: 0;">Shopping Lists</p>
        <p style="font-size: 0.75rem; color: #81826d; margin: 0;">View & manage your lists</p>
      </div>
    <% end %>

    <%= link_to deals_path,
          style: "display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: #f7f8e8; border-radius: 0.75rem; text-decoration: none; transition: background 0.15s;" do %>
      <div style="width: 2rem; height: 2rem; background: #fce4ec; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c62828" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>
        </svg>
      </div>
      <div>
        <p style="font-size: 0.875rem; font-weight: 600; color: #373928; margin: 0;">Browse Deals</p>
        <p style="font-size: 0.75rem; color: #81826d; margin: 0;">Weekly savings at your store</p>
      </div>
    <% end %>

  </div>
</div>
