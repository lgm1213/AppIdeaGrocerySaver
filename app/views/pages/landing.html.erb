    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">

      <% testimonials = [
        {
          initials: "SM", name: "Sarah M.", role: "Mom of 3, Dallas TX",
          quote: "I used to spend $250+ a week on groceries with no plan. Save & Savor got us down to $160 and we're eating so much better. The deals matching feature alone paid for itself in week one.",
          stars: 5, color: "#1a7425"
        },
        {
          initials: "JR", name: "James R.", role: "Meal prep enthusiast, Chicago IL",
          quote: "As someone who meal preps every Sunday, having everything auto-generate into a categorized shopping list is a game changer. I'm in and out of the store in 25 minutes now.",
          stars: 5, color: "#c22225"
        },
        {
          initials: "AT", name: "Anika T.", role: "Vegan household, Portland OR",
          quote: "Finding vegan deals used to mean manually searching every store flyer. Save & Savor filters everything to our diet automatically. We've cut our food bill by 35% in two months.",
