      <% testimonials.each do |t| %>
        <div class="card" style="padding: 1.75rem; display: flex; flex-direction: column; gap: 1.25rem;">
          <%# Stars %>
          <div style="display: flex; gap: 0.25rem;" aria-label="5 stars">
            <% 5.times do %>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#815f00" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <% end %>
          </div>
          <%# Quote %>
          <p style="font-size: 0.9375rem; color: #373928; line-height: 1.7; flex: 1; margin: 0; font-style: italic;">"<%= t[:quote] %>"</p>
          <%# Author %>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div class="avatar avatar-md" style="background-color: <%= t[:color] %>10; color: <%= t[:color] %>;" aria-hidden="true">
              <%= t[:initials] %>
            </div>
            <div>
              <p style="font-weight: 700; font-size: 0.9375rem; color: #373928; margin: 0;"><%= t[:name] %></p>
              <p style="font-size: 0.8125rem; color: #81826d; margin: 0;"><%= t[:role] %></p>
            </div>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</section>

