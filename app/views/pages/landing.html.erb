<% content_for :title, "Save & Savor — Plan smarter. Eat better. Save more." %>

<%# ── Sticky Nav ──────────────────────────────────────────────────────── %>
<header style="position: sticky; top: 0; z-index: 50; background: rgba(254,254,229,0.82); backdrop-filter: blur(20px) saturate(160%); -webkit-backdrop-filter: blur(20px) saturate(160%); border-bottom: 1px solid rgba(255,255,255,0.5);">
  <div class="container-app" style="display: flex; align-items: center; justify-content: space-between; padding-top: 1rem; padding-bottom: 1rem;">

    <%# Logo %>
    <a href="/" style="display: flex; align-items: center; gap: 0.625rem; text-decoration: none; flex-shrink: 0;">
      <div style="width: 2.25rem; height: 2.25rem; background-color: #1a7425; border-radius: 9999px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
          <path d="M8.5 14.5s1.5 2 3.5 2 3.5-2 3.5-2"/>
          <path d="M9 9h.01M15 9h.01"/>
        </svg>
      </div>
      <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 800; font-size: 1.1875rem; color: #373928; letter-spacing: -0.02em;">Save &amp; Savor</span>
    </a>

    <%# Nav links %>
    <nav style="display: flex; align-items: center; gap: 2rem;" aria-label="Main navigation">
      <a href="#features" style="font-size: 0.9375rem; font-weight: 500; color: #646652; text-decoration: none; transition: color 140ms;">Features</a>
      <a href="#how-it-works" style="font-size: 0.9375rem; font-weight: 500; color: #646652; text-decoration: none; transition: color 140ms;">How It Works</a>
      <a href="#testimonials" style="font-size: 0.9375rem; font-weight: 500; color: #646652; text-decoration: none; transition: color 140ms;">Reviews</a>
    </nav>

    <%# Auth CTAs %>
    <div style="display: flex; align-items: center; gap: 0.75rem;">
      <%= link_to "Sign In", new_session_path, class: "btn btn-ghost btn-sm" %>
      <%= link_to "Get Started Free", new_session_path, class: "btn btn-primary btn-sm" %>
    </div>
  </div>
</header>

<%# ── HERO ─────────────────────────────────────────────────────────────── %>
<section class="section" style="padding-top: 6rem; padding-bottom: 7rem; overflow: hidden; position: relative;">
  <%# Decorative background blob %>
  <div aria-hidden="true" style="position: absolute; top: -8rem; right: -10rem; width: 40rem; height: 40rem; background: radial-gradient(ellipse, rgba(26,116,37,0.08) 0%, transparent 70%); border-radius: 9999px; pointer-events: none;"></div>
  <div aria-hidden="true" style="position: absolute; bottom: -5rem; left: -8rem; width: 30rem; height: 30rem; background: radial-gradient(ellipse, rgba(194,34,37,0.05) 0%, transparent 70%); border-radius: 9999px; pointer-events: none;"></div>

  <div class="container-app">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;">

      <%# Left — copy %>
      <div>
        <div style="display: inline-flex; margin-bottom: 1.5rem;">
          <span class="badge badge-green" style="font-size: 0.8125rem; padding: 0.375rem 1rem;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            New: AI Meal Generator now in beta
          </span>
        </div>

        <h1 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(2.75rem, 5vw, 4rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.035em; color: #373928; margin-bottom: 1.5rem;">
          Plan smarter.<br>
          <span style="color: #1a7425;">Eat better.</span><br>
          Save more.
        </h1>

        <p style="font-size: 1.125rem; line-height: 1.75; color: #646652; margin-bottom: 2.25rem; max-width: 28rem;">
          Save &amp; Savor connects your weekly meal plan to local grocery deals — so you always know what to cook and exactly how much you'll spend before you leave the house.
        </p>

        <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
          <%= link_to "Get Started Free", new_session_path, class: "btn btn-primary btn-primary-lg" %>
          <a href="#how-it-works" class="btn btn-outline" style="font-size: 1rem; padding: 0.875rem 2rem;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
            See How It Works
          </a>
        </div>

        <%# Trust signals %>
        <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
          <div style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.875rem; color: #646652; font-weight: 500;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#1a7425" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            Free forever plan
          </div>
          <div style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.875rem; color: #646652; font-weight: 500;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#1a7425" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            No credit card needed
          </div>
          <div style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.875rem; color: #646652; font-weight: 500;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#1a7425" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            10,000+ families saving
          </div>
        </div>
      </div>

      <%# Right — decorative weekly calendar mockup %>
      <div style="position: relative;">
        <div class="card" style="padding: 1.75rem; box-shadow: 0 20px 60px rgba(55,57,40,0.12);">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
            <div>
              <p style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; font-size: 1rem; color: #373928; margin: 0;">Week of April 7</p>
              <p style="font-size: 0.8125rem; color: #81826d; margin: 0;">7 meals planned · $87 est.</p>
            </div>
            <span class="badge badge-green">On track</span>
          </div>

          <%# Mini calendar grid %>
          <% days = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"] %>
          <% meals = [
            ["Avocado Toast", "Chicken Bowl", "Salmon Pasta"],
            ["Greek Yogurt", "Turkey Wrap", "Veggie Stir-fry"],
            ["Smoothie Bowl", "Caesar Salad", "Beef Tacos"],
            ["Overnight Oats", "Lentil Soup", "Shrimp Scampi"],
            ["Egg Muffins", "Grain Bowl", "BBQ Chicken"],
            ["Banana Pancakes", "Caprese Panini", "Date Night Out"],
            ["French Toast", "Leftovers", "Sheet Pan Veggies"]
          ] %>
          <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.5rem;">
            <% days.each_with_index do |day, i| %>
              <div>
                <div style="text-align: center; font-size: 0.6875rem; font-weight: 700; color: #81826d; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem; padding-bottom: 0.5rem;">
                  <%= day %>
                </div>
                <% meals[i].each_with_index do |meal, j| %>
                  <div style="
                    padding: 0.3rem 0.4rem;
                    border-radius: 0.375rem;
                    font-size: 0.625rem;
                    font-weight: 600;
                    margin-bottom: 0.25rem;
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                    background-color: <%= j == 0 ? '#e8f5e9' : j == 1 ? '#fbfbe0' : '#fde8e8' %>;
                    color: <%= j == 0 ? '#145c1d' : j == 1 ? '#646652' : '#9e1b1d' %>;
                  ">
                    <%= meal %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>

          <%# Bottom row — deals matched %>
          <div style="margin-top: 1.25rem; padding-top: 1rem; background-color: #fbfbe0; border-radius: 0.75rem; padding: 0.875rem 1rem;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="width: 1.75rem; height: 1.75rem; background-color: #c22225; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                </div>
                <div>
                  <p style="font-size: 0.75rem; font-weight: 700; color: #373928; margin: 0;">5 deals matched</p>
                  <p style="font-size: 0.6875rem; color: #81826d; margin: 0;">Kroger · Whole Foods nearby</p>
                </div>
              </div>
              <span class="badge badge-red">Save $14</span>
            </div>
          </div>
        </div>

        <%# Floating deal card — overlapping element %>
        <div class="glass" style="position: absolute; bottom: -1.5rem; left: -2rem; padding: 0.875rem 1.125rem; min-width: 12rem;">
          <div style="display: flex; align-items: center; gap: 0.625rem;">
            <div style="width: 2.25rem; height: 2.25rem; background-color: #fdf6e3; border-radius: 0.5rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#815f00" aria-hidden="true"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
            </div>
            <div>
              <p style="font-size: 0.75rem; font-weight: 700; color: #373928; margin: 0;">Chicken Thighs</p>
              <p style="font-size: 0.6875rem; color: #81826d; margin: 0;"><span style="color: #c22225; font-weight: 700;">$2.49/lb</span> · was $4.99</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ── FEATURES ─────────────────────────────────────────────────────────── %>
<section id="features" class="section-tonal" style="padding-top: 6rem; padding-bottom: 6rem;">
  <div class="container-app">
    <div style="text-align: center; margin-bottom: 4rem;">
      <span class="badge badge-surface" style="margin-bottom: 1rem;">Everything you need</span>
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.875rem, 3.5vw, 2.75rem); font-weight: 800; letter-spacing: -0.03em; color: #373928; margin-bottom: 1rem;">
        Your kitchen, fully organized
      </h2>
      <p style="font-size: 1.0625rem; color: #646652; max-width: 36rem; margin: 0 auto; line-height: 1.7;">
        From planning to purchase, Save &amp; Savor handles every step of your weekly food routine.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">

      <%# Feature 1 — Meal Planner %>
      <div class="card card-hover" style="padding: 2rem;">
        <div style="width: 3rem; height: 3rem; background-color: #e8f5e9; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.125rem; font-weight: 700; color: #373928; margin-bottom: 0.625rem;">Weekly Meal Planner</h3>
        <p style="font-size: 0.9375rem; color: #646652; line-height: 1.65; margin: 0;">
          Drag-and-drop your week. Plan breakfast, lunch, and dinner in minutes — or let our AI generator fill it in based on your preferences.
        </p>
      </div>

      <%# Feature 2 — Grocery Deals %>
      <div class="card card-hover" style="padding: 2rem;">
        <div style="width: 3rem; height: 3rem; background-color: #fde8e8; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c22225" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/>
            <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
          </svg>
        </div>
        <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.125rem; font-weight: 700; color: #373928; margin-bottom: 0.625rem;">Local Grocery Deals</h3>
        <p style="font-size: 0.9375rem; color: #646652; line-height: 1.65; margin: 0;">
          We scan weekly flyers from Kroger, Whole Foods, Aldi, and more — then highlight deals that match exactly what's on your meal plan.
        </p>
      </div>

      <%# Feature 3 — Smart Shopping List %>
      <div class="card card-hover" style="padding: 2rem;">
        <div style="width: 3rem; height: 3rem; background-color: #fdf6e3; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#815f00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
        </div>
        <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.125rem; font-weight: 700; color: #373928; margin-bottom: 0.625rem;">Smart Shopping List</h3>
        <p style="font-size: 0.9375rem; color: #646652; line-height: 1.65; margin: 0;">
          Your meal plan automatically becomes a categorized shopping list. Scan barcodes to add extras, check items off in real-time, and track your spend.
        </p>
      </div>

      <%# Feature 4 — Budget Tracking %>
      <div class="card card-hover" style="padding: 2rem;">
        <div style="width: 3rem; height: 3rem; background-color: #e8f5e9; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.125rem; font-weight: 700; color: #373928; margin-bottom: 0.625rem;">Budget Awareness</h3>
        <p style="font-size: 0.9375rem; color: #646652; line-height: 1.65; margin: 0;">
          Set your weekly food budget and watch your estimated spend update in real-time as you plan. No more surprise totals at checkout.
        </p>
      </div>

      <%# Feature 5 — AI Generator %>
      <div class="card card-hover" style="padding: 2rem;">
        <div style="width: 3rem; height: 3rem; background-color: #fde8e8; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#c22225" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.77 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.125rem; font-weight: 700; color: #373928; margin-bottom: 0.625rem;">AI Meal Generator</h3>
        <p style="font-size: 0.9375rem; color: #646652; line-height: 1.65; margin: 0;">
          Tell us your dietary preferences, skill level, and how much time you have — we'll generate a full week of personalized meals in seconds.
        </p>
      </div>

      <%# Feature 6 — Dietary Preferences %>
      <div class="card card-hover" style="padding: 2rem;">
        <div style="width: 3rem; height: 3rem; background-color: #fdf6e3; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#815f00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.125rem; font-weight: 700; color: #373928; margin-bottom: 0.625rem;">Dietary Filters</h3>
        <p style="font-size: 0.9375rem; color: #646652; line-height: 1.65; margin: 0;">
          Vegetarian, vegan, gluten-free, keto, dairy-free — every recipe and deal filters to your household's needs automatically.
        </p>
      </div>

    </div>
  </div>
</section>

<%# ── HOW IT WORKS ─────────────────────────────────────────────────────── %>
<section id="how-it-works" class="section" style="padding-top: 6rem; padding-bottom: 6rem;">
  <div class="container-app">
    <div style="text-align: center; margin-bottom: 4.5rem;">
      <span class="badge badge-green" style="margin-bottom: 1rem;">Simple by design</span>
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.875rem, 3.5vw, 2.75rem); font-weight: 800; letter-spacing: -0.03em; color: #373928;">
        Up and running in 4 steps
      </h2>
    </div>

    <div style="display: grid; gap: 4rem;">

      <%# Step 1 %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;">
        <div>
          <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 5rem; font-weight: 800; color: #e8f5e9; line-height: 1; margin-bottom: 1rem; letter-spacing: -0.05em; user-select: none;" aria-hidden="true">01</div>
          <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.5rem; font-weight: 700; color: #373928; margin-bottom: 0.75rem;">Set your preferences</h3>
          <p style="font-size: 1rem; color: #646652; line-height: 1.7; margin-bottom: 1.5rem;">Tell us your household size, dietary needs, cooking skill level, and weekly food budget. Takes about 2 minutes.</p>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <span class="chip chip-inactive">🥦 Vegetarian</span>
            <span class="chip chip-inactive">🌾 Gluten-free</span>
            <span class="chip chip-active">🥩 Omnivore</span>
            <span class="chip chip-inactive">🥑 Keto</span>
          </div>
        </div>
        <div class="card-tonal" style="padding: 2rem; border-radius: 1.25rem;">
          <div style="margin-bottom: 1rem;">
            <p class="input-label">How many people are you feeding?</p>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem;">
              <% [1,2,3,"4+"].each_with_index do |n, i| %>
                <div style="padding: 0.75rem; border-radius: 0.625rem; text-align: center; font-weight: 600; font-size: 0.9375rem; background-color: <%= i == 1 ? '#1a7425' : '#e9eaca' %>; color: <%= i == 1 ? 'white' : '#646652' %>; cursor: pointer;"><%= n %></div>
              <% end %>
            </div>
          </div>
          <div>
            <p class="input-label">Weekly food budget</p>
            <div style="display: flex; align-items: center; gap: 0.5rem; background-color: #e9eaca; border-radius: 0.625rem; padding: 0.625rem 1rem;">
              <span style="font-weight: 600; color: #81826d;">$</span>
              <span style="font-weight: 700; font-size: 1.125rem; color: #373928;">150</span>
              <span style="color: #81826d; font-size: 0.875rem;">/week</span>
            </div>
          </div>
        </div>
      </div>

      <%# Step 2 %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;">
        <div class="card" style="order: 2; padding: 1.75rem;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
            <h4 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0;">Your AI-Generated Plan</h4>
            <span class="badge badge-green">7 meals ready</span>
          </div>
          <% ai_meals = ["Lemon Herb Salmon", "Black Bean Tacos", "Chicken Stir-fry", "Mushroom Risotto", "Greek Salad Bowl", "Turkey Meatballs", "Veggie Curry"] %>
          <% ai_meals.each_with_index do |meal, i| %>
            <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 0; <%= i < ai_meals.length - 1 ? 'border-bottom: 1px solid #f0f0d5;' : '' %>">
              <div style="width: 2rem; height: 2rem; background-color: #e8f5e9; border-radius: 9999px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.75rem; font-weight: 700; color: #1a7425;"><%= i + 1 %></div>
              <span style="font-size: 0.9rem; color: #373928; font-weight: 500;"><%= meal %></span>
              <span style="margin-left: auto; font-size: 0.8rem; color: #81826d;">~25 min</span>
            </div>
          <% end %>
        </div>
        <div style="order: 1;">
          <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 5rem; font-weight: 800; color: #fde8e8; line-height: 1; margin-bottom: 1rem; letter-spacing: -0.05em; user-select: none;" aria-hidden="true">02</div>
          <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.5rem; font-weight: 700; color: #373928; margin-bottom: 0.75rem;">Generate your meal plan</h3>
          <p style="font-size: 1rem; color: #646652; line-height: 1.7;">Our AI suggests a full week of meals tailored to your taste, budget, and schedule. Swap any meal you don't like — or build your plan manually.</p>
        </div>
      </div>

      <%# Step 3 %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;">
        <div>
          <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 5rem; font-weight: 800; color: #fdf6e3; line-height: 1; margin-bottom: 1rem; letter-spacing: -0.05em; user-select: none;" aria-hidden="true">03</div>
          <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.5rem; font-weight: 700; color: #373928; margin-bottom: 0.75rem;">Find local deals</h3>
          <p style="font-size: 1rem; color: #646652; line-height: 1.7; margin-bottom: 1.5rem;">We scan weekly flyers from stores near you and match deals to your ingredient list. See exactly where to shop and how much you'll save.</p>
          <div class="glass-dark" style="padding: 1rem 1.25rem; display: inline-flex; align-items: center; gap: 0.75rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C12.95 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/>
            </svg>
            <span style="font-size: 0.875rem; font-weight: 600; color: #373928;">Scanning 12 stores near you</span>
          </div>
        </div>
        <div style="display: grid; gap: 0.75rem;">
          <% deals_preview = [
            {store: "Kroger", item: "Organic Chicken Breast", price: "$3.49/lb", was: "$6.99", pct: "50%"},
            {store: "Whole Foods", item: "Wild Salmon Fillet", price: "$8.99/lb", was: "$14.99", pct: "40%"},
            {store: "Aldi", item: "Avocados (5 pack)", price: "$2.49", was: "$4.99", pct: "50%"}
          ] %>
          <% deals_preview.each do |deal| %>
            <div class="card" style="padding: 1rem 1.25rem; display: flex; align-items: center; gap: 0.875rem;">
              <div style="flex: 1; min-width: 0;">
                <p style="font-size: 0.6875rem; font-weight: 600; color: #81826d; text-transform: uppercase; letter-spacing: 0.05em; margin: 0;"><%= deal[:store] %></p>
                <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= deal[:item] %></p>
              </div>
              <div style="text-align: right; flex-shrink: 0;">
                <p style="font-size: 1rem; font-weight: 800; color: #c22225; margin: 0;"><%= deal[:price] %></p>
                <p style="font-size: 0.75rem; color: #81826d; text-decoration: line-through; margin: 0;"><%= deal[:was] %></p>
              </div>
              <span class="badge badge-red"><%= deal[:pct] %> off</span>
            </div>
          <% end %>
        </div>
      </div>

      <%# Step 4 %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;">
        <div class="card" style="order: 2; padding: 1.75rem;">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
            <h4 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; margin: 0; color: #373928;">Shopping List</h4>
            <span class="badge badge-surface">14 items · $87.40</span>
          </div>
          <% categories = {
            "🥦 Produce" => ["Broccoli (2 heads)", "Cherry tomatoes", "Spinach (5oz)"],
            "🥩 Meat & Fish" => ["Chicken thighs (3 lbs)", "Salmon fillet"],
            "🧀 Dairy" => ["Greek yogurt", "Parmesan cheese"]
          } %>
          <% categories.each do |cat, items| %>
            <div style="margin-bottom: 0.75rem;">
              <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0 0 0.4rem;""><%= cat %></p>
              <% items.each do |item| %>
                <div style="display: flex; align-items: center; gap: 0.625rem; padding: 0.375rem 0;">
                  <div style="width: 1.125rem; height: 1.125rem; border-radius: 9999px; border: 2px solid #babba4; flex-shrink: 0;"></div>
                  <span style="font-size: 0.875rem; color: #373928;"><%= item %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
        <div style="order: 1;">
          <div style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 5rem; font-weight: 800; color: #e8f5e9; line-height: 1; margin-bottom: 1rem; letter-spacing: -0.05em; user-select: none;" aria-hidden="true">04</div>
          <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.5rem; font-weight: 700; color: #373928; margin-bottom: 0.75rem;">Shop smart</h3>
          <p style="font-size: 1rem; color: #646652; line-height: 1.7;">Your shopping list is automatically organized by store section. Check items off on your phone. Scan barcodes to add anything extra.</p>
        </div>
      </div>

    </div>
  </div>
</section>

