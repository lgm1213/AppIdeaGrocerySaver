<turbo-frame id="deals_notification_banner">
  <div style="margin: 0 2rem; padding: 0.75rem 1rem; background: #d9f5db; border: 1px solid #a8e0ab; border-radius: 0.75rem; display: flex; align-items: center; gap: 0.75rem;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0;">
      <polyline points="20 12 20 22 4 22 4 12"/>
      <rect x="2" y="7" width="20" height="5"/>
      <line x1="12" y1="22" x2="12" y2="7"/>
      <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
      <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
    </svg>
    <p style="flex: 1; font-size: 0.875rem; font-weight: 600; color: #1a7425; margin: 0;">
      Fresh weekly deals are now available!
    </p>
    <%= link_to "View Deals →", deals_path,
          style: "font-size: 0.8125rem; font-weight: 700; color: #1a7425; text-decoration: underline; white-space: nowrap;" %>
    <%= button_to dismiss_deals_notification_path,
          method: :patch,
          style: "background: none; border: none; cursor: pointer; padding: 0.25rem; color: #1a7425; flex-shrink: 0; line-height: 1;",
          aria: { label: "Dismiss" },
          title: "Dismiss" do %>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    <% end %>
  </div>
</turbo-frame>
