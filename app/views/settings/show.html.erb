<% content_for :page_title, "Settings" %>
<% content_for :header_actions do %>
  <%= link_to edit_settings_path, class: "btn btn-primary" do %>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
    </svg>
    Edit Profile
  <% end %>
<% end %>

<div style="max-width: 40rem; display: flex; flex-direction: column; gap: 1.25rem;">

  <%# Profile card %>
  <div class="card" style="padding: 1.75rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1.25rem;">Profile</h2>
    <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.5rem;">
      <div class="avatar avatar-xl" aria-hidden="true"><%= @user.initials %></div>
      <div>
        <p style="font-size: 1.125rem; font-weight: 700; color: #373928; margin: 0 0 0.25rem;"><%= @user.name %></p>
        <p style="font-size: 0.875rem; color: #81826d; margin: 0;"><%= @user.email_address %></p>
        <% if @user.provider.present? %>
          <span class="badge badge-green" style="margin-top: 0.375rem;">Google Account</span>
        <% end %>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div style="background-color: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Display Name</p>
        <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0;"><%= @user.name %></p>
      </div>
      <div style="background-color: #f7f8e8; border-radius: 0.75rem; padding: 1rem;">
        <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Email</p>
        <p style="font-size: 0.9375rem; font-weight: 600; color: #373928; margin: 0; word-break: break-all;"><%= @user.email_address %></p>
      </div>
    </div>
  </div>

  <%# Preferences summary card %>
  <div class="card" style="padding: 1.75rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0;">Meal Preferences</h2>
      <%= link_to edit_preferences_path, class: "btn btn-sm btn-outline" do %>Edit<% end %>
    </div>

    <% pref = @user.user_preference %>
    <% if pref %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.875rem;">
        <div>
          <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Household</p>
          <p style="font-size: 0.9375rem; color: #373928; margin: 0;"><%= pref.household_size %> <%= "person".pluralize(pref.household_size) %></p>
        </div>
        <div>
          <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Weekly Budget</p>
          <p style="font-size: 0.9375rem; color: #373928; margin: 0;"><%= pref.budget_display %></p>
        </div>
        <div>
          <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Cooking Skill</p>
          <p style="font-size: 0.9375rem; color: #373928; margin: 0;"><%= pref.skill_label %></p>
        </div>
        <div>
          <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.25rem;">Preferred Store</p>
          <p style="font-size: 0.9375rem; color: #373928; margin: 0;"><%= pref.preferred_store.presence || "Not set" %></p>
        </div>
        <div style="grid-column: 1 / -1;">
          <p style="font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #81826d; margin: 0 0 0.375rem;">Dietary</p>
          <p style="font-size: 0.9375rem; color: #373928; margin: 0;"><%= pref.dietary_label %></p>
        </div>
      </div>
    <% else %>
      <p style="color: #81826d; font-size: 0.875rem;">No preferences set. <%= link_to "Set them up", edit_preferences_path, style: "color: #1a7425; font-weight: 600;" %></p>
    <% end %>
  </div>

  <%# Email notifications card %>
  <div class="card" style="padding: 1.75rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 1rem;">Email Notifications</h2>

    <% pref = @user.user_preference %>
    <% if pref %>
      <%= form_with model: pref, url: preferences_path, method: :patch do |f| %>
        <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer;">
          <%= f.hidden_field :email_deal_alerts, value: "0" %>
          <%= f.check_box :email_deal_alerts, style: "width: 1.125rem; height: 1.125rem; accent-color: #1a7425; cursor: pointer;", value: "1", checked: pref.email_deal_alerts %>
          <span style="font-size: 0.9375rem; color: #373928;">Receive weekly deal alert emails</span>
        </label>
        <p style="font-size: 0.8125rem; color: #81826d; margin: 0.5rem 0 1rem 1.875rem;">
          We'll email you when ingredients from your favorite recipes are on sale.
        </p>
        <%= f.submit "Save", class: "btn btn-sm btn-outline" %>
      <% end %>
    <% else %>
      <p style="color: #81826d; font-size: 0.875rem;">Complete your preferences to manage email settings.</p>
    <% end %>
  </div>

  <%# Danger zone %>
  <div class="card" style="padding: 1.75rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #c22225; margin: 0 0 0.75rem;">Sign Out</h2>
    <p style="font-size: 0.875rem; color: #646652; margin: 0 0 1rem;">You'll need to sign back in to access your meal plans.</p>
    <%= button_to session_path,
          method: :delete,
          class: "btn btn-sm",
          style: "background-color: #fde8e8; color: #c22225;",
          form: { "data-turbo" => "false" } do %>
      Sign out
    <% end %>
  </div>
</div>
