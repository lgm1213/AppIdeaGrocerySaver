<% content_for :progress_percent, "90%" %>

<div>
  <div style="margin-bottom: 2.5rem;">
    <span class="badge badge-green" style="margin-bottom: 0.875rem;">Step 3 of 3</span>
    <h1 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2rem; font-weight: 800; color: #373928; margin: 0 0 0.5rem; letter-spacing: -0.03em;">
      Here's your profile
    </h1>
    <p style="font-size: 1rem; color: #646652; margin: 0; line-height: 1.6;">
      Everything look right? You can always update these from your settings.
    </p>
  </div>

  <% if @user_preference %>

    <%# ── Summary cards ─────────────────────────────────────────────── %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">

      <%# Household %>
      <div class="card" style="padding: 1.25rem;">
        <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.5rem;">
          <div style="width: 2rem; height: 2rem; background-color: #e8f5e9; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0;">Household</p>
        </div>
        <p style="font-size: 1.25rem; font-weight: 700; color: #373928; margin: 0;"><%= @user_preference.household_size %> <%= @user_preference.household_size == 1 ? 'person' : 'people' %></p>
      </div>

      <%# Budget %>
      <div class="card" style="padding: 1.25rem;">
        <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.5rem;">
          <div style="width: 2rem; height: 2rem; background-color: #e8f5e9; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1a7425" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0;">Weekly Budget</p>
        </div>
        <p style="font-size: 1.25rem; font-weight: 700; color: #373928; margin: 0;"><%= @user_preference.budget_display %></p>
      </div>

      <%# Cooking skill %>
      <div class="card" style="padding: 1.25rem;">
        <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.5rem;">
          <div style="width: 2rem; height: 2rem; background-color: #fde8e8; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c22225" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
              <line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
          </div>
          <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0;">Cooking Skill</p>
        </div>
        <p style="font-size: 1.25rem; font-weight: 700; color: #373928; margin: 0;"><%= @user_preference.skill_label %></p>
      </div>

      <%# Location %>
      <div class="card" style="padding: 1.25rem;">
        <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.5rem;">
          <div style="width: 2rem; height: 2rem; background-color: #fdf6e3; border-radius: 9999px; display: flex; align-items: center; justify-content: center;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#815f00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.05 11.5 7.35 11.76a1 1 0 0 0 1.3 0C12.95 21.5 20 15.4 20 10a8 8 0 0 0-8-8z"/>
            </svg>
          </div>
          <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0;">Location</p>
        </div>
        <p style="font-size: 1.25rem; font-weight: 700; color: #373928; margin: 0;">
          <%= @user_preference.zip_code.present? ? @user_preference.zip_code : "Not set" %>
        </p>
      </div>
    </div>

    <%# Dietary restrictions %>
    <div class="card" style="padding: 1.25rem; margin-bottom: 1.25rem;">
      <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0 0 0.625rem;">Dietary preferences</p>
      <% if @user_preference.dietary_restrictions.present? && @user_preference.dietary_restrictions.reject(&:blank?).any? %>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
          <% @user_preference.dietary_restrictions.reject(&:blank?).each do |r| %>
            <span class="badge badge-green"><%= r.humanize.titleize %></span>
          <% end %>
        </div>
      <% else %>
        <p style="color: #646652; margin: 0; font-size: 0.9375rem;">No restrictions — I eat everything!</p>
      <% end %>
    </div>

    <%# Preferred store %>
    <% if @user_preference.preferred_store.present? %>
      <div class="card" style="padding: 1.25rem; margin-bottom: 1.5rem;">
        <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0 0 0.375rem;">Preferred store</p>
        <p style="font-size: 1rem; font-weight: 600; color: #373928; margin: 0;"><%= @user_preference.preferred_store %></p>
      </div>
    <% end %>

  <% else %>
    <div class="card-tonal" style="padding: 2rem; text-align: center; margin-bottom: 1.5rem;">
      <p style="color: #646652;">No preferences saved yet.</p>
      <%= link_to "← Go back to preferences", onboarding_preferences_path, class: "btn btn-ghost btn-sm" %>
    </div>
  <% end %>

  <%# ── Edit links ─────────────────────────────────────────────────── %>
  <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2rem;">
    <%= link_to "Edit preferences", onboarding_preferences_path, class: "btn btn-ghost btn-sm" %>
    <%= link_to "Edit budget &amp; location".html_safe, onboarding_budget_location_path, class: "btn btn-ghost btn-sm" %>
  </div>

  <%# ── Confirm and launch ─────────────────────────────────────────── %>
  <%= button_to onboarding_complete_path, method: :post,
        class: "btn btn-primary btn-primary-lg",
        style: "width: 100%; justify-content: center;" do %>
    🌱 Launch my Save &amp; Savor account →
  <% end %>
</div>
