<% content_for :page_title, "Edit Email Settings" %>
<% content_for :page_subtitle, "Changes apply to ActionMailer immediately — no restart needed" %>
<% content_for :header_actions do %>
  <%= link_to "← View Settings", admin_email_settings_path,
        style: "font-size: 0.875rem; color: #6b7280; text-decoration: none; font-weight: 500;" %>
<% end %>

<div style="max-width: 640px;">
  <%= form_with url: admin_email_settings_path, method: :patch, style: "display: flex; flex-direction: column; gap: 1.25rem;" do |f| %>

    <div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem;">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #111827; margin: 0 0 1.25rem;">Server Settings</h2>

      <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1rem; margin-bottom: 1rem;">
        <div>
          <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;">SMTP Host</label>
          <input type="text" name="email_settings[smtp_address]" value="<%= @settings['smtp_address'] %>"
                 placeholder="smtp.sendgrid.net"
                 style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.875rem; box-sizing: border-box;">
        </div>
        <div>
          <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;">Port</label>
          <input type="number" name="email_settings[smtp_port]" value="<%= @settings['smtp_port'] || 587 %>"
                 style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.875rem; box-sizing: border-box;">
        </div>
      </div>

      <div style="margin-bottom: 1rem;">
        <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;">Domain</label>
        <input type="text" name="email_settings[smtp_domain]" value="<%= @settings['smtp_domain'] %>"
               placeholder="yourdomain.com"
               style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.875rem; box-sizing: border-box;">
      </div>

      <div style="margin-bottom: 1rem;">
        <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;">From Address</label>
        <input type="email" name="email_settings[smtp_from_address]" value="<%= @settings['smtp_from_address'] %>"
               placeholder="noreply@yourdomain.com"
               style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.875rem; box-sizing: border-box;">
      </div>
    </div>

    <div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem;">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #111827; margin: 0 0 1.25rem;">Authentication</h2>

      <div style="margin-bottom: 1rem;">
        <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;">Username / API Key</label>
        <input type="text" name="email_settings[smtp_username]" value="<%= @settings['smtp_username'] %>"
               placeholder="apikey or username"
               style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.875rem; box-sizing: border-box;">
      </div>

      <div style="margin-bottom: 1rem;">
        <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;">
          Password / API Key Value
          <% if @settings['smtp_password'].present? %>
            <span style="font-size: 0.75rem; font-weight: 400; color: #6b7280;">(leave blank to keep current)</span>
          <% end %>
        </label>
        <input type="password" name="email_settings[smtp_password]" value=""
               placeholder="<%= @settings['smtp_password'].present? ? '••••••••' : 'Enter password or API key' %>"
               autocomplete="new-password"
               style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.875rem; box-sizing: border-box;">
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;">Authentication Type</label>
          <select name="email_settings[smtp_authentication]"
                  style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.875rem; background: #fff; box-sizing: border-box;">
            <% %w[plain login cram_md5].each do |type| %>
              <option value="<%= type %>" <%= "selected" if @settings['smtp_authentication'] == type %>><%= type %></option>
            <% end %>
          </select>
        </div>
        <div>
          <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;">STARTTLS</label>
          <select name="email_settings[smtp_enable_starttls_auto]"
                  style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.5rem; font-size: 0.875rem; background: #fff; box-sizing: border-box;">
            <option value="true"  <%= "selected" if @settings['smtp_enable_starttls_auto'] != "false" %>>Enabled (recommended)</option>
            <option value="false" <%= "selected" if @settings['smtp_enable_starttls_auto'] == "false" %>>Disabled</option>
          </select>
        </div>
      </div>
    </div>

    <div style="display: flex; gap: 0.75rem;">
      <button type="submit" style="background: #1a7425; color: #fff; border: none; border-radius: 0.5rem; padding: 0.625rem 1.5rem; font-size: 0.875rem; font-weight: 600; cursor: pointer;">
        Save &amp; Apply Settings
      </button>
      <%= link_to "Cancel", admin_email_settings_path,
            style: "background: #f3f4f6; color: #374151; border-radius: 0.5rem; padding: 0.625rem 1.5rem; font-size: 0.875rem; font-weight: 600; text-decoration: none;" %>
    </div>

  <% end %>
</div>
