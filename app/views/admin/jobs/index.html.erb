<% content_for :page_title, "Retailer Jobs" %>
<% content_for :page_subtitle, "Manage data scrapers per grocery chain" %>
<% content_for :header_actions do %>
  <span style="font-size: 0.75rem; color: #9ca3af; display: flex; align-items: center; gap: 0.375rem;">
    <span style="width: 7px; height: 7px; background: #22c55e; border-radius: 50%; display: inline-block; animation: pulse 2s ease-in-out infinite;"></span>
    Live · refreshes every 3s
  </span>
  <%= link_to "Job History →", admin_job_executions_path,
        style: "background: #f3f4f6; color: #374151; border-radius: 0.5rem; padding: 0.5rem 0.875rem; font-size: 0.8125rem; font-weight: 600; text-decoration: none;" %>
<% end %>

<%# ── Retailer Chain Cards ──────────────────────────────────────────────── %>
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 2rem;">
  <% @chain_data.each do |chain| %>
    <div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; position: relative; overflow: hidden;">

      <%# Accent stripe %>
      <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: <%= chain[:accent] %>; border-radius: 0.75rem 0.75rem 0 0;"></div>

      <%# Icon + freshness badge %>
      <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-top: 0.25rem;">
        <div style="width: 2.75rem; height: 2.75rem; background: <%= chain[:icon_bg] %>; border-radius: 0.75rem; display: flex; align-items: center; justify-content: center;">
          <span style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.125rem; font-weight: 800; color: <%= chain[:icon_color] %>;"><%= chain[:label][0] %></span>
        </div>
        <%= chain_freshness_badge(chain[:freshness]) %>
      </div>

      <%# Chain name + last sync %>
      <div>
        <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.0625rem; font-weight: 700; color: #111827; margin: 0 0 0.25rem;"><%= chain[:label] %></h3>
        <p style="font-size: 0.8125rem; color: #9ca3af; margin: 0;">
          <%= chain[:store]&.deals_fetched_at ?
                "Last sync: #{time_ago_in_words(chain[:store].deals_fetched_at)} ago" :
                chain[:store] ? "Never synced" : "No store record — add one in seeds or admin" %>
        </p>
      </div>

      <%# Job action rows %>
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <% chain[:jobs].each do |job| %>
          <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: #f9fafb; border-radius: 0.5rem; border: 1px solid #f3f4f6;">
            <div>
              <p style="font-size: 0.875rem; font-weight: 600; color: <%= job[:dispatchable] ? '#111827' : '#9ca3af' %>; margin: 0;"><%= job[:label] %></p>
              <% if job[:setup_hint] %>
                <p style="font-size: 0.75rem; color: #f59e0b; margin: 0.125rem 0 0;"><%= job[:setup_hint] %></p>
              <% end %>
            </div>

            <% if job[:dispatchable] %>
              <%= button_to admin_jobs_path,
                    method: :post,
                    params: { job_key: job[:key], chain: chain[:key] },
                    style: "background: #{chain[:accent]}; color: #fff; border: none; border-radius: 0.375rem; padding: 0.375rem 0.75rem; font-size: 0.75rem; font-weight: 600; cursor: pointer; white-space: nowrap;" do %>
                ▶ Enqueue
              <% end %>
            <% else %>
              <span style="font-size: 0.75rem; font-weight: 600; color: #d1d5db; background: #f3f4f6; border-radius: 0.375rem; padding: 0.375rem 0.75rem; cursor: not-allowed;">Enqueue</span>
            <% end %>
          </div>
        <% end %>
      </div>

    </div>
  <% end %>
</div>

<%# ── Global Operations ────────────────────────────────────────────────── %>
<div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem; margin-bottom: 1.5rem;">
  <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #111827; margin: 0 0 1rem;">Global Operations</h2>
  <div style="display: flex; flex-direction: column; gap: 0.625rem;">
    <% Admin::JobsController::GLOBAL_JOBS.each do |key, config| %>
      <div style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; background: #f9fafb; border-radius: 0.625rem; border: 1px solid #f3f4f6;">
        <div>
          <p style="font-size: 0.9375rem; font-weight: 600; color: #111827; margin: 0 0 0.25rem;"><%= config[:label] %></p>
          <p style="font-size: 0.8125rem; color: #6b7280; margin: 0;"><%= config[:description] %></p>
        </div>
        <%= button_to admin_jobs_path,
              method: :post,
              params: { job_key: key },
              style: "background: #1a7425; color: #fff; border: none; border-radius: 0.5rem; padding: 0.5rem 1rem; font-size: 0.8125rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 0.375rem; white-space: nowrap; flex-shrink: 0; margin-left: 1rem;" do %>
          <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Enqueue All
        <% end %>
      </div>
    <% end %>

    <%# Scheduled cron reference %>
    <div style="display: flex; align-items: center; gap: 1rem; padding: 0.875rem 1.25rem; background: #f0fdf4; border-radius: 0.625rem; border: 1px solid #bbf7d0;">
      <span style="font-family: monospace; background: #dcfce7; color: #166534; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8125rem; white-space: nowrap;">0 8 * * 3</span>
      <div>
        <p style="font-size: 0.8125rem; font-weight: 600; color: #15803d; margin: 0;">Full Pipeline auto-runs every Wednesday at 8:00 AM</p>
        <p style="font-size: 0.75rem; color: #16a34a; margin: 0;">Configured in <code style="background: #dcfce7; padding: 0.1rem 0.35rem; border-radius: 3px;">config/recurring.yml</code></p>
      </div>
      <span class="admin-badge admin-badge-green" style="margin-left: auto; white-space: nowrap;">Scheduled</span>
    </div>
  </div>
</div>

<%# ── Live Activity ────────────────────────────────────────────────────── %>
<div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 1.5rem;"
     data-controller="poll"
     data-poll-src-value="<%= status_admin_jobs_path %>"
     data-poll-interval-value="3000">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
    <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #111827; margin: 0;">Live Activity</h2>
    <%= link_to "Full History →", admin_job_executions_path,
          style: "font-size: 0.8125rem; color: #6b7280; text-decoration: none; font-weight: 500;" %>
  </div>
  <%= render "activity" %>
</div>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }
</style>
