<% content_for :page_title, @recipe.name %>
<% content_for :page_subtitle, [@recipe.cuisine, @recipe.meal_type&.capitalize].compact.join(" · ") %>
<% content_for :header_actions do %>
  <%= link_to "← Recipes", recipes_path,
        style: "font-size: 0.875rem; color: #646652; text-decoration: none; font-weight: 500;" %>
<% end %>

<div style="display: grid; grid-template-columns: 1fr 340px; gap: 2rem; align-items: start;">

  <%# ── Left: main info ──────────────────────────────────────────── %>
  <div>

    <%# Stats strip %>
    <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; padding: 1rem 1.25rem; background: #fff; border: 1px solid #e8e9d4; border-radius: 0.75rem;">
      <div style="text-align: center;">
        <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0 0 0.25rem;">Prep</p>
        <p style="font-size: 1rem; font-weight: 700; color: #373928; margin: 0;"><%= @recipe.prep_time_minutes || 0 %> min</p>
      </div>
      <div style="text-align: center;">
        <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0 0 0.25rem;">Cook</p>
        <p style="font-size: 1rem; font-weight: 700; color: #373928; margin: 0;"><%= @recipe.cook_time_minutes || 0 %> min</p>
      </div>
      <div style="text-align: center;">
        <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0 0 0.25rem;">Servings</p>
        <p style="font-size: 1rem; font-weight: 700; color: #373928; margin: 0;"><%= @recipe.servings %></p>
      </div>
      <div style="text-align: center;">
        <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0 0 0.25rem;">Est. Cost</p>
        <p style="font-size: 1rem; font-weight: 700; color: #373928; margin: 0;"><%= @recipe.cost_display %></p>
      </div>
      <div style="text-align: center;">
        <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #81826d; margin: 0 0 0.25rem;">Difficulty</p>
        <p style="font-size: 1rem; font-weight: 700; color: #373928; margin: 0; text-transform: capitalize;"><%= @recipe.difficulty %></p>
      </div>
    </div>

    <%# Description %>
    <% if @recipe.description.present? %>
      <p style="color: #4a5040; font-size: 0.9375rem; line-height: 1.6; margin-bottom: 1.5rem;"><%= @recipe.description %></p>
    <% end %>

    <%# Ingredients %>
    <div style="background: #fff; border: 1px solid #e8e9d4; border-radius: 0.75rem; padding: 1.25rem; margin-bottom: 1.25rem;">
      <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 0.875rem;">
        Ingredients
        <% if @on_sale_deals.any? %>
          <span style="background: #dcfce7; color: #15803d; font-size: 0.75rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 9999px; margin-left: 0.5rem;">
            <%= @on_sale_deals.count %> on sale!
          </span>
        <% end %>
      </h2>
      <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem;">
        <% @recipe.recipe_ingredients.each do |ri| %>
          <% deal = @on_sale_deals.find { |d| d.ingredient_id == ri.ingredient_id } %>
          <li style="display: flex; align-items: center; justify-content: space-between; font-size: 0.875rem;">
            <span style="color: #373928;">
              <% if ri.quantity %>
                <span style="color: #81826d; margin-right: 0.25rem;"><%= ri.quantity %> <%= ri.unit %></span>
              <% end %>
              <%= ri.ingredient&.name || "Unknown ingredient" %>
            </span>
            <% if deal %>
              <span style="background: #dcfce7; color: #15803d; font-size: 0.7rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 9999px; white-space: nowrap;">
                <%= deal.savings_label %>
              </span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <%# Instructions %>
    <% if @recipe.instructions.present? %>
      <div style="background: #fff; border: 1px solid #e8e9d4; border-radius: 0.75rem; padding: 1.25rem;">
        <h2 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700; color: #373928; margin: 0 0 0.875rem;">Instructions</h2>
        <div style="color: #4a5040; font-size: 0.9375rem; line-height: 1.7; white-space: pre-line;">
          <%= @recipe.instructions %>
        </div>
      </div>
    <% end %>

  </div>

  <%# ── Right: rating + community ──────────────────────────────── %>
  <div style="display: flex; flex-direction: column; gap: 1.25rem; position: sticky; top: 5rem;">

    <%# Your rating card %>
    <div style="background: #fff; border: 1px solid #e8e9d4; border-radius: 0.875rem; padding: 1.25rem;">
      <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #373928; margin: 0 0 0.875rem;">Your Rating</h3>
      <%= render "recipes/rating_widget", recipe: @recipe, preference: @preference %>
      <% if @preference&.cooked_count.to_i > 0 %>
        <p style="font-size: 0.75rem; color: #81826d; margin: 0.75rem 0 0;">
          Cooked <%= @preference.cooked_count %> time<%= @preference.cooked_count == 1 ? "" : "s" %>
          <% if @preference.last_cooked_at %>· last <%= time_ago_in_words(@preference.last_cooked_at) %> ago<% end %>
        </p>
      <% end %>
    </div>

    <%# Community rating card %>
    <div style="background: #fff; border: 1px solid #e8e9d4; border-radius: 0.875rem; padding: 1.25rem;">
      <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #373928; margin: 0 0 0.875rem;">Community Rating</h3>
      <% if @recipe.ratings_count > 0 %>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <%= render "recipes/star_display", rating: @recipe.average_rating, size: "md" %>
          <div>
            <p style="font-size: 1.5rem; font-weight: 800; color: #373928; margin: 0; font-family: 'Plus Jakarta Sans', sans-serif;">
              <%= "%.1f" % @recipe.average_rating %>
            </p>
            <p style="font-size: 0.75rem; color: #81826d; margin: 0;">
              <%= @recipe.ratings_count %> rating<%= @recipe.ratings_count == 1 ? "" : "s" %>
            </p>
          </div>
        </div>
      <% else %>
        <p style="font-size: 0.875rem; color: #9ca3af; margin: 0;">No community ratings yet. Be the first!</p>
      <% end %>
    </div>

    <%# Dietary badges %>
    <% if @recipe.dietary_badges.any? %>
      <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 0.875rem; padding: 1rem 1.25rem;">
        <h3 style="font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #15803d; margin: 0 0 0.5rem;">Dietary</h3>
        <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
          <% @recipe.dietary_badges.each do |badge| %>
            <span style="background: #dcfce7; color: #15803d; font-size: 0.8125rem; font-weight: 600; padding: 0.25rem 0.625rem; border-radius: 9999px;"><%= badge %></span>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>
