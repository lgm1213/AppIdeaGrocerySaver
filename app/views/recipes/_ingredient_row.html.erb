<%# locals: (index:, ingredient_id:, quantity:, unit:, ingredients:) %>
<div data-ingredient-rows-target="row"
     style="display:grid; grid-template-columns:2fr 1fr 1fr auto; gap:0.5rem; margin-bottom:0.5rem; align-items:center;">

  <select name="recipes_submission[ingredient_rows][<%= index %>][ingredient_id]"
          style="width:100%; padding:0.4375rem 0.75rem; border:1px solid #e8e9d4; border-radius:0.5rem; font-size:0.875rem; background:#fff;">
    <option value="">Select ingredient…</option>
    <% ingredients.each do |ing| %>
      <option value="<%= ing.id %>" <%= "selected" if ing.id.to_s == ingredient_id.to_s %>><%= ing.name %></option>
    <% end %>
  </select>

  <input type="number" step="0.01" min="0"
         name="recipes_submission[ingredient_rows][<%= index %>][quantity]"
         value="<%= quantity %>"
         placeholder="Qty"
         style="width:100%; padding:0.4375rem 0.75rem; border:1px solid #e8e9d4; border-radius:0.5rem; font-size:0.875rem; box-sizing:border-box;">

  <select name="recipes_submission[ingredient_rows][<%= index %>][unit]"
          style="width:100%; padding:0.4375rem 0.75rem; border:1px solid #e8e9d4; border-radius:0.5rem; font-size:0.875rem; background:#fff;">
    <option value="">Unit</option>
    <% %w[cup tbsp tsp oz lb g kg each slice clove bunch can bag].each do |u| %>
      <option value="<%= u %>" <%= "selected" if u == unit %>><%= u %></option>
    <% end %>
  </select>

  <button type="button"
          data-action="ingredient-rows#removeRow"
          aria-label="Remove ingredient"
          style="padding:0.375rem 0.625rem; background:#fff; border:1px solid #e8e9d4; border-radius:0.5rem; color:#9ca3af; cursor:pointer; font-size:0.875rem;">
    &times;
  </button>

</div>
