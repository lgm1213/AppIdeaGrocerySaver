<%# Locals: recipe, preference (UserRecipePreference|nil), on_sale_deal (Deal|nil) %>
<% preference  ||= nil
   on_sale_deal ||= nil %>

<div style="background: #fff; border: 1px solid #e8e9d4; border-radius: 0.875rem; overflow: hidden; display: flex; flex-direction: column; transition: box-shadow 0.15s;"
     onmouseenter="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.08)'"
     onmouseleave="this.style.boxShadow='none'">

  <%# Meal type + on-sale badge %>
  <div style="padding: 0.875rem 1rem 0; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;">
    <span style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #81826d;">
      <%= recipe.meal_type %>
    </span>
    <% if on_sale_deal %>
      <span style="background: #dcfce7; color: #15803d; font-size: 0.7rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 9999px;">
        <%= on_sale_deal.savings_label %> ON SALE
      </span>
    <% end %>
    <% if preference&.liked == true %>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="#ef4444" stroke="none" title="Liked">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    <% end %>
  </div>

  <%# Name + link %>
  <%= link_to recipe_path(recipe), style: "text-decoration: none; flex: 1; display: flex; flex-direction: column; padding: 0.5rem 1rem 0.875rem;" do %>
    <h3 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.9375rem; font-weight: 700; color: #373928; margin: 0 0 0.375rem; line-height: 1.3;">
      <%= recipe.name %>
    </h3>

    <%# Stats row %>
    <div style="display: flex; align-items: center; gap: 0.75rem; font-size: 0.75rem; color: #81826d; margin-bottom: 0.5rem; flex-wrap: wrap;">
      <span title="Total time">⏱ <%= recipe.total_time_label %></span>
      <span title="Estimated cost">💰 <%= recipe.cost_display %></span>
      <% if recipe.cuisine.present? %>
        <span><%= recipe.cuisine %></span>
      <% end %>
    </div>

    <%# Community rating %>
    <div style="display: flex; align-items: center; gap: 0.375rem; margin-top: auto;">
      <%= render "recipes/star_display", rating: recipe.average_rating, size: "sm" %>
      <span style="font-size: 0.7rem; color: #9ca3af;">
        <% if recipe.ratings_count > 0 %>
          <%= "%.1f" % recipe.average_rating %> (<%= recipe.ratings_count %>)
        <% else %>
          No ratings yet
        <% end %>
      </span>
    </div>

    <%# Dietary badges %>
    <% if recipe.dietary_badges.any? %>
      <div style="display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.5rem;">
        <% recipe.dietary_badges.each do |badge| %>
          <span style="background: #f0fdf4; color: #15803d; font-size: 0.6875rem; font-weight: 600; padding: 0.1rem 0.4rem; border-radius: 9999px;"><%= badge %></span>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
