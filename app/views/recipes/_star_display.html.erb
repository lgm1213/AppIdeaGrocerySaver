<%# Read-only star display. Locals: rating (0..5 decimal), size ("sm"|"md") %>
<% rating ||= 0
   size   ||= "sm"
   px      = size == "md" ? 18 : 14 %>
<span style="display: inline-flex; gap: 1px;" aria-label="<%= "%.1f" % rating %> out of 5 stars">
  <% (1..5).each do |i| %>
    <svg width="<%= px %>" height="<%= px %>" viewBox="0 0 24 24" fill="<%= i <= rating.round ? '#f59e0b' : '#d1d5db' %>" stroke="none" aria-hidden="true">
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
    </svg>
  <% end %>
</span>
